---
// BaseLayout.astro
import '../styles/global.css';

const SITE = 'https://www.saralemaitre.com';
const CALENDLY = 'https://calendly.com/sara-lemaitre-herbalist';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
  navLight?: boolean;       // true = page has light-coloured hero
  currentPage?: string;     // e.g. 'therapies' — highlights active nav link
  ogType?: string;
  schema?: object | object[]; // page-specific JSON-LD
}

const {
  title,
  description,
  ogImage = `${SITE}/images/og-default.jpg`,
  canonical = SITE,
  navLight = false,
  currentPage = '',
  ogType = 'website',
  schema,
} = Astro.props;

const navPages = [
  { id: 'therapies',   label: 'Therapies',    href: '/therapies',    i18n: 'nav.therapies' },
  { id: 'workshops',   label: 'Workshops',    href: '/workshops',    i18n: 'nav.workshops' },
  { id: 'walks',       label: 'Walks',        href: '/walks',        i18n: 'nav.walks'     },
  { id: 'consultancy', label: 'Consultancy',  href: '/consultancy',  i18n: 'nav.consultancy' },
  { id: 'pricing',     label: 'Pricing',      href: '/pricing',      i18n: 'nav.pricing'   },
  { id: 'story',       label: 'My story',     href: '/story',        i18n: 'nav.story'     },
];

// Book button: context-aware per page
const bookHref = currentPage === 'consultancy' ? '#contact'
               : currentPage === 'walks'       ? '#mailing'
               : currentPage === 'book'        ? CALENDLY
               : '/book';
const bookLabel = currentPage === 'consultancy' ? 'Get in touch'
                : currentPage === 'walks'       ? 'Get walk dates'
                : currentPage === 'book'        ? 'Book free call'
                : 'Book a consultation';
const bookI18n  = currentPage === 'consultancy' ? 'nav.consultancy.cta'
                : currentPage === 'walks'       ? 'nav.walks.cta'
                : 'nav.book';
const bookTarget = bookHref.startsWith('http') ? '_blank' : undefined;

// Shared Person + Business schema (every page)
const sharedSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${SITE}/#sara`,
      "name": "Sara Lemaitre",
      "jobTitle": "Clinical Herbalist and Naturopath",
      "url": SITE,
      "knowsLanguage": ["en-GB", "fr-FR"],
      "hasCredential": [
        {"@type":"EducationalOccupationalCredential","credentialCategory":"degree","name":"BSc Herbal Medicine (EHTPA accredited)"},
        {"@type":"EducationalOccupationalCredential","credentialCategory":"diploma","name":"Naturopathy Diploma"},
        {"@type":"EducationalOccupationalCredential","credentialCategory":"diploma","name":"Indian Head Massage Diploma"},
        {"@type":"EducationalOccupationalCredential","credentialCategory":"training","name":"TCM Dispensary Externship, 6 months"}
      ]
    },
    {
      "@type": ["MedicalBusiness","HealthAndBeautyBusiness"],
      "@id": `${SITE}/#practice`,
      "name": "Sara Lemaitre Herbal Medicine & Naturopathy",
      "url": SITE,
      "priceRange": "££",
      "currenciesAccepted": "GBP",
      "areaServed": ["United Kingdom","France","Belgium","Switzerland","Canada","Australia","United States"],
      "availableLanguage": [{"@type":"Language","name":"English"},{"@type":"Language","name":"French"}]
    }
  ]
};

const schemas = [sharedSchema, ...(schema ? (Array.isArray(schema) ? schema : [schema]) : [])];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>

  <!-- SEO -->
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />
  <meta name="author" content="Sara Lemaitre" />
  <meta name="geo.region" content="GB" />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Sara Lemaitre Herbal Medicine & Naturopathy" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="en_GB" />
  <meta property="og:locale:alternate" content="fr_FR" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Canonical & hreflang -->
  <link rel="canonical" href={canonical} />
  <link rel="alternate" hreflang="en-gb" href={canonical} />
  <link rel="alternate" hreflang="fr" href={canonical} />
  <link rel="alternate" hreflang="x-default" href={canonical} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />


  <!-- Schema.org JSON-LD -->
  {schemas.map(s => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
</head>

<body data-nav={navLight ? 'light' : undefined}>

  <!-- Skip nav -->
  <a href="#main-content" class="skip-nav" data-i18n="nav.skip">Skip to main content</a>

  <!-- NAV -->
  <nav id="nav" role="navigation" aria-label="Main navigation">
    <a href="/" class="nav-logo"
       aria-current={currentPage === 'index' ? 'page' : undefined}>
      Sara Lemaitre
    </a>

    <ul class="nav-links" id="nav-links">
      {navPages.map(p => (
        <li>
          <a
            href={p.href}
            data-i18n={p.i18n}
            aria-current={currentPage === p.id ? 'page' : undefined}
          >{p.label}</a>
        </li>
      ))}
    </ul>

    <a
      href={bookHref}
      class="nav-book"
      data-i18n={bookI18n}
      target={bookTarget}
      rel={bookTarget ? 'noopener noreferrer' : undefined}
    >{bookLabel}</a>

    <button
      class="lang-toggle"
      data-current-lang="en"
      aria-label="Switch to French"
      onclick="SL_toggleLang(this)"
    >FR</button>

    <button
      class="hamburger"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="nav-links"
      onclick="toggleNav(this)"
    >
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- PAGE CONTENT -->
  <slot />

  <!-- FOOTER -->
  <footer>
    <div class="footer-grid">
      <div class="footer-brand">
        <span class="logo">Sara Lemaitre</span>
        <p>Clinical herbalist, naturopath and former elite athlete. Specialising in hormonal health, endometriosis, PCOS, chronic fatigue, and performance recovery. Online and in person. English &amp; French.</p>
      </div>
      <div>
        <p class="footer-col-title">Practice</p>
        <ul class="footer-links">
          <li><a href="/therapies">Therapies</a></li>
          <li><a href="/pricing">Pricing &amp; packages</a></li>
          <li><a href="/story">My story</a></li>
          <li><a href="/workshops">Workshops</a></li>
          <li><a href="/walks">Holistic walks</a></li>
        </ul>
      </div>
      <div>
        <p class="footer-col-title">Specialisms</p>
        <ul class="footer-links">
          <li><a href="/therapies#herbal">Hormonal health</a></li>
          <li><a href="/therapies#athlete">Athletes &amp; performance</a></li>
          <li><a href="/therapies#ihm">Indian head massage</a></li>
          <li><a href="/therapies#naturopathy">Naturopathy</a></li>
          <li><a href="/therapies#tcm">TCM &amp; integrative</a></li>
        </ul>
      </div>
      <div>
        <p class="footer-col-title">Connect</p>
        <ul class="footer-links">
          <li><a href="#" aria-label="Instagram">Instagram</a></li>
          <li><a href="#" aria-label="LinkedIn">LinkedIn</a></li>
          <li><a href="/consultancy">Consultancy</a></li>
          <li><a href={CALENDLY} target="_blank" rel="noopener">Book a call</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© 2025 Sara Lemaitre · Herbal Medicine &amp; Naturopathy · <a href="/legal" style="color:rgba(247,243,238,.4);text-decoration:none;">Legal &amp; privacy</a></p>
      <p>Consultations in English &amp; French · UK registered practitioner · Online &amp; in person</p>
    </div>
  </footer>

  <!-- Scripts -->
  <script src="/translations.js" is:inline></script>
  <script src="/i18n.js" is:inline></script>

  <script>
    // Nav scroll effect
    const nav = document.getElementById('nav');
    if (nav) {
      window.addEventListener('scroll', () => {
        nav.classList.toggle('scrolled', window.scrollY > 60);
      });
    }

    // Hamburger menu
    function toggleNav(btn) {
      const navLinks = document.getElementById('nav-links');
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      btn.setAttribute('aria-label', expanded ? 'Open navigation menu' : 'Close navigation menu');
      navLinks?.classList.toggle('open', !expanded);
    }

    document.addEventListener('click', (e) => {
      const navLinks = document.getElementById('nav-links');
      const btn = document.querySelector('.hamburger');
      if (navLinks && btn && !navLinks.contains(e.target) && !btn.contains(e.target)) {
        navLinks.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
        btn.setAttribute('aria-label', 'Open navigation menu');
      }
    });

    // Scroll reveal
    const reveals = document.querySelectorAll('.reveal');
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
      });
    }, { threshold: 0.07, rootMargin: '0px 0px -40px 0px' });
    reveals.forEach(r => obs.observe(r));
  </script>

</body>
</html>
