---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found — Sara Lemaitre"
  description="This page could not be found."
  navLight={true}
>
<style is:global>
  .notfound { flex: 1; display: flex; align-items: center; justify-content: center; text-align: center; padding: 8rem 2rem; min-height: 70vh; }
  .notfound h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(3rem,8vw,7rem); font-weight: 300; color: var(--sage-light); margin-bottom: 1rem; }
  .notfound p { font-size: 1.0625rem; color: var(--muted); margin-bottom: 2rem; }
  .notfound a { display: inline-block; padding: .9rem 2.2rem; border: 1px solid var(--bark); color: var(--bark); text-decoration: none; font-size: .9375rem; letter-spacing: .16em; text-transform: uppercase; transition: all .22s; }
  .notfound a:hover { background: var(--bark); color: var(--warm-white); }
</style>

<div id="main-content" class="notfound">
  <div>
    <h1>404</h1>
    <p>This page doesn't exist or has moved.</p>
    <a href="/">Back to home</a>
  </div>
</div>

</BaseLayout>
