---
import BaseLayout from '../layouts/BaseLayout.astro';

const meta = {
  title: "Four Seasons Holistic Walks | Botanical Guided Walks UK | Sara Lemaitre",
  description: "Guided seasonal botanical walks with a clinical herbalist. Plant identification, foraging, seasonal herbal medicine and shinrin-yoku. Spring through winter. Small groups. UK.",
  ogImage: "https://www.saralemaitre.com/images/og-walks.jpg",
  canonical: "https://www.saralemaitre.com/walks",
  navLight: false,
  currentPage: 'walks',
  ogType: 'website',
};
---

<BaseLayout {...meta}>

<style is:global>
:root {
    --cream: #F7F3EE; --warm-white: #FDFAF7;
    --sage: #7A8C6E;
    --sage-text: #4E6245; --sage-light: #C4D0BA; --sage-pale: #EBF0E7;
    --bark: #5C4A3A; --bark-light: #8C7060; --bark-pale: #EDE5DC;
    --charcoal: #2A2420; --muted: #6A5E58;
    --spring: #8BA888; --spring-pale: #E8F0E6;
    --summer: #C4A25A; --summer-pale: #F7EFD8;
    --autumn: #A0634A; --autumn-pale: #F5E4D8;
    --winter: #5A6E82; --winter-pale: #E2E8EF;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { background: var(--warm-white); color: var(--charcoal); font-family: 'Jost', sans-serif; font-weight: 300; line-height: 1.8; overflow-x: hidden; }

  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 1.5rem 4rem; display: flex; justify-content: space-between; align-items: center; background: rgba(253,250,247,0); backdrop-filter: blur(0px); border-bottom: 1px solid transparent; transition: all .4s; }
  nav.scrolled { background: rgba(253,250,247,0.93); backdrop-filter: blur(10px); border-bottom-color: rgba(122,108,100,0.1); }
  .nav-logo { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; font-weight: 400; letter-spacing: .12em; text-transform: uppercase; color: var(--cream); text-decoration: none; transition: color .4s; }
  nav.scrolled .nav-logo { color: var(--bark); }
  .nav-links { display: flex; gap: 2.5rem; list-style: none; }
  .nav-links a { font-size: .9375rem; letter-spacing: .14em; text-transform: uppercase; color: rgba(247,243,238,.7); text-decoration: none; transition: color .2s; }
  nav.scrolled .nav-links a { color: var(--muted); }
  .nav-links a:hover, .nav-links a.active { color: var(--cream) !important; }
  nav.scrolled .nav-links a:hover, nav.scrolled .nav-links a.active { color: var(--bark) !important; }
  .nav-book { font-size: .9375rem; letter-spacing: .16em; text-transform: uppercase; padding: .7rem 1.8rem; border: 1px solid rgba(247,243,238,.4); color: rgba(247,243,238,.8); text-decoration: none; transition: all .22s; }
  nav.scrolled .nav-book { border-color: var(--bark); color: var(--bark); }
  .nav-book:hover { background: rgba(247,243,238,.15); }
  nav.scrolled .nav-book:hover { background: var(--bark); color: var(--warm-white); }

  /* HERO — full screen, nature feel */
  .hero { min-height: 100vh; background: var(--sage); position: relative; display: flex; align-items: flex-end; overflow: hidden; }
  .hero-bg { position: absolute; inset: 0; background: linear-gradient(160deg, #4a6b3e 0%, #7A8C6E 40%, #5C4A3A 100%); }
  /* layered tree silhouettes */
  .hero-trees { position: absolute; bottom: 0; left: 0; right: 0; }
  .hero-content { position: relative; z-index: 2; padding: 0 8rem 8rem; max-width: 800px; }
  .hero-eyebrow { font-size: .75rem; letter-spacing: .26em; text-transform: uppercase; color: var(--sage-pale); margin-bottom: 2rem; opacity: 0; animation: fadeUp .8s .2s forwards; }
  .hero-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(3.5rem, 7vw, 6rem); font-weight: 300; line-height: 1.0; color: var(--cream); margin-bottom: 2rem; opacity: 0; animation: fadeUp .8s .35s forwards; }
  .hero-title em { font-style: italic; color: var(--sage-light); display: block; }
  .hero-desc { font-size: 1.125rem; color: rgba(247,243,238,.72); line-height: 1.95; max-width: 540px; margin-bottom: 3rem; opacity: 0; animation: fadeUp .8s .5s forwards; }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; opacity: 0; animation: fadeUp .8s .65s forwards; }
  .btn-cream { display: inline-block; padding: .95rem 2.5rem; background: var(--cream); color: var(--bark); text-decoration: none; font-size: .9375rem; letter-spacing: .18em; text-transform: uppercase; transition: all .22s; }
  .btn-cream:hover { background: var(--sage-pale); }
  .btn-outline-cream { display: inline-block; padding: .95rem 2.5rem; border: 1px solid rgba(247,243,238,.35); color: rgba(247,243,238,.75); text-decoration: none; font-size: .9375rem; letter-spacing: .18em; text-transform: uppercase; transition: all .22s; }
  .btn-outline-cream:hover { border-color: rgba(247,243,238,.6); color: var(--cream); }
  /* scroll hint */
  .scroll-hint { position: absolute; bottom: 3rem; right: 8rem; display: flex; align-items: center; gap: .8rem; opacity: 0; animation: fadeIn 1s 1.2s forwards; z-index: 2; }
  .scroll-hint span { font-size: .75rem; letter-spacing: .2em; text-transform: uppercase; color: rgba(247,243,238,.4); }
  .scroll-line { width: 40px; height: 1px; background: rgba(247,243,238,.25); }

  /* OPENING */
  .opening { padding: 8rem; display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center; border-bottom: 1px solid rgba(122,108,100,0.1); }
  .opening h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.2rem, 3.5vw, 3.2rem); font-weight: 300; color: var(--bark); line-height: 1.15; }
  .opening h2 em { font-style: italic; color: var(--sage-text); }
  .opening-eyebrow { font-size: .75rem; letter-spacing: .22em; text-transform: uppercase; color: var(--sage-text); margin-bottom: 1.5rem; }
  .opening p { font-size: 1.0625rem; color: #4A403C; line-height: 1.95; margin-bottom: 1.3rem; }
  .opening p:last-child { margin-bottom: 0; }
  .opening p em { font-style: italic; color: var(--sage-text); }

  /* WHAT TO EXPECT */
  .expect { background: var(--cream); padding: 6rem 8rem; border-bottom: 1px solid rgba(122,108,100,0.1); }
  .expect-header { margin-bottom: 4rem; }
  .expect-header .eyebrow { font-size: .75rem; letter-spacing: .22em; text-transform: uppercase; color: var(--sage-text); margin-bottom: 1.2rem; }
  .expect-header h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.8rem, 2.5vw, 2.4rem); font-weight: 300; color: var(--bark); line-height: 1.2; }
  .expect-header h2 em { font-style: italic; color: var(--sage-text); }
  .expect-grid { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 2rem; }
  .expect-card { padding: 2rem; background: var(--warm-white); border: 1px solid rgba(122,108,100,0.1); }
  .expect-card-icon { font-size: 1.6rem; margin-bottom: 1rem; }
  .expect-card-title { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; font-weight: 400; color: var(--bark); margin-bottom: .6rem; }
  .expect-card-desc { font-size: 1rem; color: var(--muted); line-height: 1.8; }

  /* FOUR SEASONS — one full section per season */
  .season-section { display: grid; grid-template-columns: 1fr 1fr; min-height: 75vh; border-bottom: 1px solid rgba(122,108,100,0.08); }
  .season-section.reverse { direction: rtl; }
  .season-section.reverse > * { direction: ltr; }

  .season-visual { position: relative; overflow: hidden; display: flex; flex-direction: column; justify-content: flex-end; padding: 4rem; }
  .season-visual::before { content: ''; position: absolute; inset: 0; }
  .season-section:nth-child(1) .season-visual { background: var(--spring-pale); }
  .season-section:nth-child(1) .season-visual::before { background: linear-gradient(160deg, rgba(139,168,136,.25) 0%, rgba(235,240,231,.8) 100%); }
  .season-section:nth-child(2) .season-visual { background: var(--summer-pale); }
  .season-section:nth-child(2) .season-visual::before { background: linear-gradient(160deg, rgba(196,162,90,.2) 0%, rgba(247,239,216,.85) 100%); }
  .season-section:nth-child(3) .season-visual { background: var(--autumn-pale); }
  .season-section:nth-child(3) .season-visual::before { background: linear-gradient(160deg, rgba(160,99,74,.2) 0%, rgba(245,228,216,.85) 100%); }
  .season-section:nth-child(4) .season-visual { background: var(--winter-pale); }
  .season-section:nth-child(4) .season-visual::before { background: linear-gradient(160deg, rgba(90,110,130,.2) 0%, rgba(226,232,239,.85) 100%); }

  .season-large-text { position: absolute; top: 2rem; left: 3rem; font-family: 'Cormorant Garamond', serif; font-size: 8rem; font-weight: 300; line-height: 1; opacity: .12; pointer-events: none; }
  .season-section:nth-child(1) .season-large-text { color: var(--spring); }
  .season-section:nth-child(2) .season-large-text { color: var(--summer); }
  .season-section:nth-child(3) .season-large-text { color: var(--autumn); }
  .season-section:nth-child(4) .season-large-text { color: var(--winter); }

  .season-visual-svg { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); opacity: .18; }
  .season-quote { position: relative; z-index: 1; font-family: 'Cormorant Garamond', serif; font-size: 1.15rem; font-style: italic; color: var(--bark); line-height: 1.6; border-left: 2px solid var(--sage-light); padding-left: 1.2rem; max-width: 340px; }

  .season-content { padding: 6rem; display: flex; flex-direction: column; justify-content: center; }
  .season-indicator { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem; }
  .season-dot { width: 10px; height: 10px; border-radius: 50%; }
  .spring-dot { background: var(--spring); }
  .summer-dot { background: var(--summer); }
  .autumn-dot { background: var(--autumn); }
  .winter-dot { background: var(--winter); }
  .season-name-label { font-size: .75rem; letter-spacing: .22em; text-transform: uppercase; color: var(--muted); }

  .season-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 3vw, 2.8rem); font-weight: 300; color: var(--bark); line-height: 1.15; margin-bottom: .5rem; }
  .season-title em { font-style: italic; }
  .season-section:nth-child(1) .season-title em { color: var(--spring); }
  .season-section:nth-child(2) .season-title em { color: var(--summer); }
  .season-section:nth-child(3) .season-title em { color: var(--autumn); }
  .season-section:nth-child(4) .season-title em { color: var(--winter); }

  .season-subtitle { font-size: 1rem; color: var(--muted); margin-bottom: 2rem; }
  .season-body { font-size: 1.0625rem; color: #4A403C; line-height: 1.95; margin-bottom: 1.2rem; max-width: 540px; }
  .season-body em { font-style: italic; color: var(--sage-text); }
  .season-body strong { font-weight: 500; color: var(--bark); }

  .herbs-block { margin: 1.8rem 0; padding: 1.4rem 1.8rem; background: var(--cream); border-left: 3px solid var(--sage-light); }
  .herbs-label { font-size: .75rem; letter-spacing: .18em; text-transform: uppercase; color: var(--sage-text); margin-bottom: .8rem; }
  .herbs-list { display: flex; flex-wrap: wrap; gap: .5rem; }
  .herb-chip { font-size: .9375rem; padding: .25rem .9rem; background: var(--warm-white); border: 1px solid rgba(122,140,110,0.25); color: var(--bark-light); border-radius: 20px; font-style: italic; }

  .season-meta { display: flex; gap: 2rem; flex-wrap: wrap; margin-top: 2rem; padding-top: 2rem; border-top: 1px solid rgba(122,108,100,0.1); }
  .season-meta-item { display: flex; flex-direction: column; gap: .15rem; }
  .season-meta-label { font-size: .75rem; letter-spacing: .18em; text-transform: uppercase; color: var(--sage-text); }
  .season-meta-value { font-size: 1rem; color: var(--bark); font-weight: 400; }
  .season-book { display: inline-block; margin-top: 1.5rem; padding: .85rem 2.2rem; border: 1px solid var(--bark); color: var(--bark); text-decoration: none; font-size: .9375rem; letter-spacing: .16em; text-transform: uppercase; transition: all .22s; }
  .season-book:hover { background: var(--bark); color: var(--warm-white); }

  /* RETREAT SECTION */
  .retreat-section { background: var(--bark); padding: 8rem; display: grid; grid-template-columns: 1.2fr 1fr; gap: 6rem; align-items: center; border-bottom: 1px solid rgba(122,108,100,0.1); }
  .retreat-text .eyebrow { font-size: .75rem; letter-spacing: .22em; text-transform: uppercase; color: var(--sage-light); margin-bottom: 1.5rem; }
  .retreat-text h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 3vw, 2.8rem); font-weight: 300; color: var(--cream); line-height: 1.2; margin-bottom: 2rem; }
  .retreat-text h2 em { font-style: italic; color: var(--sage-light); }
  .retreat-text p { font-size: 1.0625rem; color: rgba(247,243,238,.7); line-height: 1.95; margin-bottom: 1.3rem; max-width: 500px; }
  .retreat-features { display: flex; flex-direction: column; gap: 0; }
  .retreat-feature { padding: 1.4rem 0; border-bottom: 1px solid rgba(247,243,238,.08); display: flex; gap: 1.2rem; align-items: flex-start; }
  .retreat-feature:first-child { border-top: 1px solid rgba(247,243,238,.08); }
  .retreat-feature-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--sage-light); flex-shrink: 0; margin-top: .55rem; }
  .retreat-feature-title { font-size: 1rem; font-weight: 400; color: var(--cream); margin-bottom: .2rem; }
  .retreat-feature-desc { font-size: .9375rem; color: rgba(247,243,238,.45); line-height: 1.5; }
  .retreat-cta { display: inline-block; margin-top: 2rem; padding: .9rem 2.4rem; background: var(--sage-light); color: var(--bark); text-decoration: none; font-size: .9375rem; letter-spacing: .18em; text-transform: uppercase; transition: all .22s; }
  .retreat-cta:hover { background: var(--cream); }

  /* PRACTICAL INFO */
  .practical { padding: 6rem 8rem; background: var(--cream); border-bottom: 1px solid rgba(122,108,100,0.1); }
  .practical .eyebrow { font-size: .75rem; letter-spacing: .22em; text-transform: uppercase; color: var(--sage-text); margin-bottom: 1.5rem; }
  .practical h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.8rem, 2.5vw, 2.4rem); font-weight: 300; color: var(--bark); line-height: 1.2; margin-bottom: 3rem; }
  .practical h2 em { font-style: italic; color: var(--sage-text); }
  .practical-grid { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 2rem; }
  .practical-item { padding: 2rem; background: var(--warm-white); border: 1px solid rgba(122,108,100,0.1); }
  .practical-item-title { font-size: 1rem; font-weight: 500; color: var(--bark); margin-bottom: .6rem; }
  .practical-item-body { font-size: 1rem; color: var(--muted); line-height: 1.75; }

  /* MAILING */
  .mailing { padding: 7rem 8rem; display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center; border-bottom: 1px solid rgba(122,108,100,0.1); }
  .mailing-text .eyebrow { font-size: .75rem; letter-spacing: .22em; text-transform: uppercase; color: var(--sage-text); margin-bottom: 1.5rem; }
  .mailing-text h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.8rem, 2.5vw, 2.4rem); font-weight: 300; color: var(--bark); line-height: 1.2; margin-bottom: 1.5rem; }
  .mailing-text h2 em { font-style: italic; color: var(--sage-text); }
  .mailing-text p { font-size: 1rem; color: var(--muted); line-height: 1.9; }
  .mailing-form { display: flex; flex-direction: column; gap: 1rem; }
  .mailing-form input { padding: .9rem 1.2rem; border: 1px solid rgba(122,108,100,0.2); background: var(--warm-white); font-family: 'Jost', sans-serif; font-size: 1.0625rem; color: var(--charcoal); outline: none; transition: border-color .2s; }
  .mailing-form input:focus { border-color: var(--sage-text); }
  .mailing-form input::placeholder { color: var(--muted); }
  .mailing-form button { padding: .9rem 2rem; background: var(--sage); color: var(--cream); border: none; font-family: 'Jost', sans-serif; font-size: .9375rem; letter-spacing: .18em; text-transform: uppercase; cursor: pointer; transition: background .22s; }
  .mailing-form button:hover { background: var(--bark); }
  .mailing-note { font-size: .9375rem; color: var(--muted); }

  footer { background: var(--charcoal); padding: 3rem 8rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
  footer p { font-size: .9375rem; letter-spacing: .08em; color: rgba(247,243,238,.25); }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  .reveal { opacity: 0; transform: translateY(22px); transition: opacity .75s ease, transform .75s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  .reveal-d1 { transition-delay: .12s; } .reveal-d2 { transition-delay: .22s; }

  @media (max-width: 1000px) {
    nav { padding: 1.2rem 2rem; }
    .hero-content { padding: 0 2.5rem 5rem; }
    .scroll-hint { display: none; }
    .opening { grid-template-columns: 1fr; padding: 5rem 2.5rem; gap: 3rem; }
    .expect { padding: 5rem 2.5rem; }
    .expect-grid { grid-template-columns: 1fr; }
    .season-section, .season-section.reverse { grid-template-columns: 1fr; direction: ltr; }
    .season-visual { min-height: 300px; }
    .season-content { padding: 4rem 2.5rem; }
    .retreat-section { grid-template-columns: 1fr; padding: 5rem 2.5rem; gap: 3rem; }
    .practical { padding: 5rem 2.5rem; }
    .practical-grid { grid-template-columns: 1fr; }
    .mailing { grid-template-columns: 1fr; padding: 5rem 2.5rem; gap: 3rem; }
    footer { padding: 2rem 2.5rem; flex-direction: column; text-align: center; }
  }

  /* ── WCAG 2.2 AA: Visible focus indicators ── */
  :focus-visible {
    outline: 3px solid #5C4A3A;
    outline-offset: 3px;
    border-radius: 2px;
  }
  a:focus-visible, button:focus-visible, input:focus-visible,
  select:focus-visible, textarea:focus-visible {
    outline: 3px solid #5C4A3A;
    outline-offset: 3px;
  }

  /* Screen-reader only utility */
  .sr-only {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }

  /* ── Skip navigation link ── */
  .skip-nav {
    position: absolute; top: -100px; left: 1rem; z-index: 9999;
    background: #5C4A3A; color: #F7F3EE;
    padding: .75rem 1.5rem; font-size: 1.0625rem;
    text-decoration: none; border-radius: 0 0 4px 4px;
    transition: top .2s;
  }
  .skip-nav:focus { top: 0; }


  /* ── Mobile hamburger menu ── */
  .hamburger {
    display: none; flex-direction: column; gap: 5px;
    background: none; border: none; cursor: pointer;
    padding: .5rem; margin-left: .5rem;
  }
  .hamburger span {
    display: block; width: 22px; height: 2px;
    background: var(--bark); border-radius: 2px;
    transition: all .25s;
  }
  .hamburger[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .hamburger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  
  @media (max-width: 1024px) {
    .hamburger { display: flex; }
    .nav-links {
      display: none; position: fixed; top: 73px; left: 0; right: 0;
      background: rgba(253,250,247,0.98); backdrop-filter: blur(12px);
      flex-direction: column; gap: 0; padding: 1rem 0;
      border-bottom: 1px solid rgba(122,108,100,0.12);
      z-index: 99;
    }
    .nav-links.open { display: flex; }
    .nav-links li a {
      display: block; padding: .9rem 2rem;
      font-size: 1.0625rem; letter-spacing: .08em;
      border-bottom: 1px solid rgba(122,108,100,0.06);
    }
    .nav-book { display: none; }
  }



  .lang-toggle {
    font-size: .75rem; letter-spacing: .16em; text-transform: uppercase;
    padding: .45rem .9rem; border: 1px solid rgba(247,243,238,.5);
    background: none; color: rgba(247,243,238,.85); cursor: pointer;
    font-family: 'Jost', sans-serif; border-radius: 2px;
    transition: all .3s; margin-left: .5rem;
  }
  nav.scrolled .lang-toggle { border-color: rgba(92,74,58,.35); color: var(--muted); }
  .lang-toggle:hover, nav.scrolled .lang-toggle:hover { border-color: var(--bark); color: var(--bark); }


  /* Pages with light-coloured heroes — nav starts dark */
  body[data-nav="light"] nav {
    background: rgba(253,250,247,0.85);
    backdrop-filter: blur(8px);
  }
  body[data-nav="light"] .nav-logo { color: var(--bark); }
  body[data-nav="light"] .nav-links a { color: var(--muted); }
  body[data-nav="light"] .nav-links a:hover { color: var(--bark); }
  body[data-nav="light"] .nav-book { border-color: var(--bark); color: var(--bark); }
  body[data-nav="light"] .lang-toggle { border-color: rgba(92,74,58,.35); color: var(--muted); }
</style>

<!-- HERO -->
<section id="main-content" role="main" class="hero">
  <div class="hero-bg"></div>
  <!-- Tree silhouettes -->
  <svg class="hero-trees" viewBox="0 0 1440 300" fill="none" preserveAspectRatio="xMidYMax meet" style="position:absolute;bottom:0;left:0;right:0;width:100%;opacity:.18;">
    <path d="M0 300 L0 180 Q60 120 80 80 Q100 120 120 180 L120 300Z" fill="#2A2420"/>
