---
import BaseLayout from '../../layouts/BaseLayout.astro';

const meta = {
  title: "Sara Lemaitre | Herboriste Clinique & Naturopathe | Santé Hormonale, Endométriose, SOPK",
  description: "Herboriste clinique et naturopathe spécialisée en endométriose, SOPK et fatigue chronique. Ancienne athlète de haut niveau. Consultations en ligne en français et en anglais.",
  ogImage: "https://www.saralemaitre.com/images/og-home.jpg",
  canonical: "https://www.saralemaitre.com/fr",
  navLight: false,
  currentPage: 'index',
  ogType: 'website',
  lang: 'fr',
};

// Load French content from data files
const homepage = await import('../../data/fr/homepage.json');
const settings = await import('../../data/fr/settings.json');
const CALENDLY_FR = settings.default.calendlyUrl || 'https://calendly.com/sara-lemaitre-herbalist';
---

<BaseLayout {...meta}>

<style is:global>
:root {
    --cream: #F7F3EE;
    --warm-white: #FDFAF7;
    --sage: #7A8C6E;
    --sage-text: #4E6245;
    --sage-light: #C4D0BA;
    --sage-pale: #EBF0E7;
    --bark: #5C4A3A;
    --bark-light: #8C7060;
    --bark-pale: #EDE5DC;
    --charcoal: #2A2420;
    --muted: #6A5E58;
    --gold: #C4A25A;
    --gold-pale: #F5EDD6;
    --plum-pale: #F0EAF0;
    --amber-pale: #FBF0E3;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--warm-white);
    color: var(--charcoal);
    font-family: 'Jost', sans-serif;
    font-size: 1.0625rem;
    font-weight: 300;
    line-height: 1.85;
    overflow-x: hidden;
  }

  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 1.5rem 4rem;
    display: flex; justify-content: space-between; align-items: center;
    background: rgba(92,74,58,0.15);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid transparent;
    transition: background .4s, backdrop-filter .4s, border-color .4s;
  }
  nav.scrolled {
    background: rgba(253,250,247,0.96);
    backdrop-filter: blur(12px);
    border-bottom-color: rgba(122,108,100,0.1);
  }
  .nav-logo { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; font-weight: 400; letter-spacing: .12em; text-transform: uppercase; color: var(--cream); text-decoration: none; transition: color .4s; }
  nav.scrolled .nav-logo { color: var(--bark); }
  .nav-links { display: flex; gap: 2.5rem; list-style: none; }
  .nav-links a { font-size: .9375rem; letter-spacing: .14em; text-transform: uppercase; color: rgba(247,243,238,.85); text-decoration: none; transition: color .2s; }
  nav.scrolled .nav-links a { color: var(--muted); }
  .nav-links a:hover, nav.scrolled .nav-links a:hover { color: var(--bark); }
  .nav-book { font-size: .9375rem; letter-spacing: .16em; text-transform: uppercase; padding: .7rem 1.8rem; border: 1px solid rgba(247,243,238,.7); color: rgba(247,243,238,.9); text-decoration: none; transition: all .22s; }
  nav.scrolled .nav-book { border-color: var(--bark); color: var(--bark); }
  .nav-book:hover { background: var(--cream); color: var(--bark) !important; border-color: var(--cream) !important; }
  .lang-toggle { font-size: .75rem; letter-spacing: .16em; text-transform: uppercase; padding: .45rem .9rem; border: 1px solid rgba(247,243,238,.4); background: none; color: rgba(247,243,238,.7); cursor: pointer; font-family: 'Jost', sans-serif; border-radius: 2px; transition: all .2s; margin-left: .5rem; }
  nav.scrolled .lang-toggle { border-color: rgba(92,74,58,.35); color: var(--muted); }
  .hamburger { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: .5rem; margin-left: .5rem; }
  .hamburger span { display: block; width: 22px; height: 2px; background: var(--cream); border-radius: 2px; transition: all .25s; }
  nav.scrolled .hamburger span { background: var(--bark); }

  .hero { min-height: 100vh; display: grid; grid-template-columns: 1fr 1fr; position: relative; }
  .hero-left { background: var(--bark); padding: 12rem 6rem 8rem; display: flex; flex-direction: column; justify-content: flex-end; position: relative; overflow: hidden; }
  .hero-left::before { content: ''; position: absolute; inset: 0; background: linear-gradient(145deg, #3d2e22 0%, #5C4A3A 60%, #6e5a48 100%); }
  .hero-eyebrow { position: relative; font-size: .75rem; letter-spacing: .26em; text-transform: uppercase; color: rgba(196,208,186,.7); margin-bottom: 2rem; }
  .hero-name { position: relative; font-family: 'Cormorant Garamond', serif; font-size: clamp(3rem, 5vw, 5rem); font-weight: 300; line-height: 1.05; color: var(--cream); margin-bottom: 1.5rem; }
  .hero-name em { font-style: italic; color: var(--sage-light); display: block; }
  .hero-credentials { position: relative; font-size: .9375rem; color: rgba(247,243,238,.45); letter-spacing: .08em; line-height: 2; margin-bottom: 2.5rem; }
  .hero-desc { position: relative; font-size: 1.0625rem; color: rgba(247,243,238,.65); line-height: 1.9; max-width: 420px; margin-bottom: 3rem; }
  .hero-actions { position: relative; display: flex; gap: 1rem; flex-wrap: wrap; }
  .btn-primary { display: inline-block; padding: .95rem 2.5rem; background: var(--sage-light); color: var(--bark); text-decoration: none; font-size: .9375rem; letter-spacing: .18em; text-transform: uppercase; transition: all .22s; }
  .btn-primary:hover { background: var(--cream); }
  .btn-ghost { display: inline-block; padding: .95rem 2.5rem; border: 1px solid rgba(247,243,238,.25); color: rgba(247,243,238,.6); text-decoration: none; font-size: .9375rem; letter-spacing: .18em; text-transform: uppercase; transition: all .22s; }
  .btn-ghost:hover { border-color: var(--sage-light); color: var(--sage-light); }
  .hero-right { background: var(--sage-pale); display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
  .hero-botanical { width: 420px; height: 420px; opacity: .6; }
  .scroll-hint { position: absolute; bottom: 3rem; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: .6rem; }
  .scroll-hint span { font-size: .6875rem; letter-spacing: .22em; text-transform: uppercase; color: var(--sage-text); }
  .scroll-line { width: 1px; height: 40px; background: linear-gradient(to bottom, var(--sage-light), transparent); animation: scrollPulse 2s ease-in-out infinite; }
  .hero-bar { background: var(--charcoal); padding: 1.8rem 8rem; display: flex; gap: 0; align-items: center; }
  .hero-bar-item { flex: 1; display: flex; flex-direction: column; gap: .3rem; }
  .hero-bar-label { font-size: .6875rem; letter-spacing: .2em; text-transform: uppercase; color: rgba(196,208,186,.5); }
  .hero-bar-value { font-size: .9375rem; color: rgba(247,243,238,.7); }
  .hero-bar-divider { width: 1px; height: 40px; background: rgba(247,243,238,.08); margin: 0 3rem; }

  .intro-strip { padding: 7rem 8rem; display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: start; border-bottom: 1px solid rgba(122,108,100,0.1); }
  .intro-strip-left .eyebrow { font-size: .75rem; letter-spacing: .22em; text-transform: uppercase; color: var(--sage-text); margin-bottom: 1.5rem; }
  .intro-strip-left h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 3vw, 2.8rem); font-weight: 400; color: var(--charcoal); line-height: 1.2; }
  .intro-strip-left h2 em { font-style: italic; color: var(--sage-text); }
  .intro-strip-right p { font-size: 1.0625rem; color: var(--muted); line-height: 1.95; margin-bottom: 1.3rem; }
  .read-more { font-size: .8125rem; letter-spacing: .16em; text-transform: uppercase; color: var(--bark); text-decoration: none; border-bottom: 1px solid rgba(92,74,58,.3); padding-bottom: 2px; transition: border-color .2s; }
  .read-more:hover { border-color: var(--bark); }

  .who-section { padding: 7rem 8rem; background: var(--cream); }
  .who-header { margin-bottom: 5rem; }
  .who-header h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.2rem, 3.5vw, 3.2rem); font-weight: 400; color: var(--charcoal); line-height: 1.15; margin-bottom: 1.2rem; }
  .who-header h2 em { font-style: italic; color: var(--sage-text); }
  .who-header-desc { font-size: 1.0625rem; color: var(--muted); max-width: 600px; line-height: 1.85; }
  .who-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; }
  .who-card { background: var(--warm-white); padding: 3rem 2.5rem; border: 1px solid rgba(122,108,100,0.08); }
  .who-card-number { font-family: 'Cormorant Garamond', serif; font-size: 3rem; font-weight: 300; color: var(--sage-light); line-height: 1; margin-bottom: 1.5rem; }
  .who-card-title { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; font-weight: 400; color: var(--charcoal); margin-bottom: 1rem; line-height: 1.3; }
  .who-card-desc { font-size: .9375rem; color: var(--muted); line-height: 1.8; margin-bottom: 1.5rem; }
  .who-card-tags { display: flex; flex-wrap: wrap; gap: .4rem; }
  .who-tag { font-size: .6875rem; letter-spacing: .12em; text-transform: uppercase; padding: .3rem .7rem; background: var(--sage-pale); color: var(--sage-text); }

  .different-section { padding: 7rem 8rem; display: grid; grid-template-columns: 1fr 1.2fr; gap: 7rem; align-items: start; }
  .different-left .eyebrow { font-size: .75rem; letter-spacing: .22em; text-transform: uppercase; color: var(--sage-text); margin-bottom: 1.5rem; }
  .different-left h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 3vw, 2.8rem); font-weight: 400; color: var(--charcoal); line-height: 1.2; margin-bottom: 2rem; }
  .different-left h2 em { font-style: italic; color: var(--sage-text); }
  .different-left p { font-size: 1.0625rem; color: var(--muted); line-height: 1.95; margin-bottom: 1.2rem; }
  .diff-item { display: flex; gap: 1.5rem; padding: 1.8rem 0; border-bottom: 1px solid rgba(122,108,100,0.1); }
  .diff-item:first-child { border-top: 1px solid rgba(122,108,100,0.1); }
  .diff-num { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 300; color: var(--sage-light); min-width: 2rem; padding-top: .1rem; }
  .diff-text-title { font-size: 1rem; font-weight: 400; color: var(--charcoal); margin-bottom: .5rem; }
  .diff-text-body { font-size: .9375rem; color: var(--muted); line-height: 1.75; }

  .therapies-section { padding: 7rem 8rem; background: var(--charcoal); }
  .therapies-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 4rem; }
  .therapies-header h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.2rem, 3.5vw, 3rem); font-weight: 400; color: var(--cream); line-height: 1.15; }
  .therapies-header h2 em { font-style: italic; color: var(--sage-light); }
  .therapies-header a { font-size: .8125rem; letter-spacing: .16em; text-transform: uppercase; color: var(--sage-light); text-decoration: none; opacity: .7; transition: opacity .2s; }
  .therapies-header a:hover { opacity: 1; }
  .therapies-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: rgba(247,243,238,.05); }
  .therapy-card { background: var(--charcoal); padding: 2.5rem 2rem; text-decoration: none; border: 1px solid rgba(247,243,238,.05); transition: background .2s; display: flex; flex-direction: column; gap: 1rem; }
  .therapy-card:hover { background: rgba(122,140,110,0.08); }
  .therapy-card-icon { width: 48px; height: 48px; margin-bottom: .5rem; }
  .therapy-card-title { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; font-weight: 400; color: var(--cream); }
  .therapy-card-desc { font-size: .875rem; color: rgba(247,243,238,.45); line-height: 1.75; flex: 1; }
  .therapy-card-link { font-size: .75rem; letter-spacing: .16em; text-transform: uppercase; color: var(--sage-light); opacity: .6; }

  .story-pull { padding: 7rem 8rem; display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center; background: var(--bark-pale); }
  .story-pull-text .eyebrow { font-size: .75rem; letter-spacing: .22em; text-transform: uppercase; color: var(--sage-text); margin-bottom: 1.5rem; }
  .story-pull-text h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.2rem, 3.5vw, 3rem); font-weight: 400; color: var(--charcoal); line-height: 1.15; margin-bottom: 2rem; }
  .story-pull-text h2 em { font-style: italic; color: var(--sage-text); }
  .story-pull-text p { font-size: 1.0625rem; color: var(--muted); line-height: 1.9; margin-bottom: 2rem; }
  .btn-bark { display: inline-block; padding: .9rem 2.4rem; border: 1px solid var(--bark); color: var(--bark); text-decoration: none; font-size: .9375rem; letter-spacing: .18em; text-transform: uppercase; transition: all .22s; }
  .btn-bark:hover { background: var(--bark); color: var(--warm-white); }
  .story-pull-visual { display: flex; align-items: center; justify-content: center; }
  .story-quote { padding: 3rem; border: 1px solid rgba(92,74,58,.2); background: var(--warm-white); }
  .story-quote p { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; font-weight: 300; font-style: italic; color: var(--charcoal); line-height: 1.6; margin-bottom: 1.5rem; }
  .story-quote cite { font-size: .8125rem; letter-spacing: .14em; text-transform: uppercase; color: var(--muted); }

  .process-section { padding: 7rem 8rem; border-bottom: 1px solid rgba(122,108,100,0.1); }
  .process-header { margin-bottom: 5rem; }
  .process-header .eyebrow { font-size: .75rem; letter-spacing: .22em; text-transform: uppercase; color: var(--sage-text); margin-bottom: 1.5rem; }
  .process-header h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.2rem, 3.5vw, 3rem); font-weight: 400; color: var(--charcoal); line-height: 1.15; }
  .process-header h2 em { font-style: italic; color: var(--sage-text); }
  .process-steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 3rem; }
  .process-step { display: flex; flex-direction: column; gap: 1rem; }
  .process-dot { width: 2.5rem; height: 2.5rem; border-radius: 50%; border: 1px solid var(--sage-light); display: flex; align-items: center; justify-content: center; font-size: .6875rem; letter-spacing: .12em; color: var(--sage-text); }
  .process-step-title { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; font-weight: 400; color: var(--charcoal); }
  .process-step-desc { font-size: .9375rem; color: var(--muted); line-height: 1.75; }

  .testimonials-section { padding: 7rem 8rem; background: var(--cream); }
  .testimonials-header { margin-bottom: 4rem; }
  .testimonials-header .eyebrow { font-size: .75rem; letter-spacing: .22em; text-transform: uppercase; color: var(--sage-text); margin-bottom: 1.5rem; }
  .testimonials-header h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.2rem, 3.5vw, 3rem); font-weight: 400; color: var(--charcoal); line-height: 1.15; }
  .testimonials-header h2 em { font-style: italic; color: var(--sage-text); }
  .testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  .testimonial-card { background: var(--warm-white); padding: 2.5rem; border: 1px solid rgba(122,108,100,0.08); }
  .testimonial-card.placeholder { opacity: .5; }
  .testimonial-text { font-family: 'Cormorant Garamond', serif; font-size: 1.125rem; font-style: italic; color: var(--charcoal); line-height: 1.7; margin-bottom: 1.5rem; }
  .testimonial-author { font-size: .8125rem; font-weight: 500; color: var(--bark); }
  .testimonial-condition { font-size: .75rem; letter-spacing: .12em; text-transform: uppercase; color: var(--muted); margin-top: .3rem; }

  .international-section { padding: 7rem 8rem; display: grid; grid-template-columns: 1fr 1fr; gap: 7rem; align-items: start; }
  .international-text .eyebrow { font-size: .75rem; letter-spacing: .22em; text-transform: uppercase; color: var(--sage-text); margin-bottom: 1.5rem; }
  .international-text h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 3vw, 2.8rem); font-weight: 400; color: var(--charcoal); line-height: 1.2; margin-bottom: 2rem; }
  .international-text h2 em { font-style: italic; color: var(--sage-text); }
  .international-text p { font-size: 1.0625rem; color: var(--muted); line-height: 1.95; margin-bottom: 1.3rem; }
  .lang-flags { display: flex; gap: 1rem; margin-top: 1rem; }
  .lang-pill { font-size: .8125rem; padding: .4rem 1rem; background: var(--sage-pale); color: var(--sage-text); border: 1px solid var(--sage-light); }
  .regions-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: rgba(122,108,100,0.1); }
  .region-item { background: var(--warm-white); padding: 1.5rem; }
  .region-name { font-size: .9375rem; font-weight: 400; color: var(--charcoal); margin-bottom: .4rem; }
  .region-desc { font-size: .875rem; color: var(--muted); line-height: 1.6; }

  .final-cta { padding: 9rem 8rem; background: var(--sage); text-align: center; position: relative; overflow: hidden; }
  .final-cta::before { content: ''; position: absolute; inset: -50%; background: radial-gradient(ellipse at center, rgba(255,255,255,0.04) 0%, transparent 70%); }
  .final-cta .eyebrow { position: relative; font-size: .75rem; letter-spacing: .26em; text-transform: uppercase; color: rgba(235,240,231,.6); margin-bottom: 2rem; }
  .final-cta h2 { position: relative; font-family: 'Cormorant Garamond', serif; font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 300; color: var(--cream); line-height: 1.15; margin-bottom: 1.5rem; }
  .final-cta h2 em { font-style: italic; }
  .final-cta p { position: relative; font-size: 1.0625rem; color: rgba(247,243,238,.65); max-width: 520px; margin: 0 auto 3rem; line-height: 1.85; }
  .cta-buttons { position: relative; display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap; }
  .cta-btn-primary { display: inline-block; padding: 1.1rem 3rem; background: var(--bark); color: var(--cream); text-decoration: none; font-size: .9375rem; letter-spacing: .18em; text-transform: uppercase; transition: all .22s; }
  .cta-btn-primary:hover { background: var(--charcoal); }
  .cta-btn-secondary { display: inline-block; padding: 1.1rem 3rem; border: 1px solid rgba(247,243,238,.35); color: rgba(247,243,238,.75); text-decoration: none; font-size: .9375rem; letter-spacing: .18em; text-transform: uppercase; transition: all .22s; }
  .cta-btn-secondary:hover { border-color: var(--cream); color: var(--cream); }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(22px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes scrollPulse { 0%,100% { opacity: .3; transform: scaleY(1); } 50% { opacity: 1; transform: scaleY(1.2); } }
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity .75s ease, transform .75s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  .reveal-delay-1 { transition-delay: .1s; }
  .reveal-delay-2 { transition-delay: .2s; }
  .reveal-delay-3 { transition-delay: .3s; }

  @media (max-width: 1024px) {
    nav { padding: 1.2rem 2rem; }
    .hamburger { display: flex; }
    .nav-links { display: none; position: fixed; top: 73px; left: 0; right: 0; background: rgba(253,250,247,0.98); backdrop-filter: blur(12px); flex-direction: column; gap: 0; padding: 1rem 0; border-bottom: 1px solid rgba(122,108,100,0.12); z-index: 99; }
    .nav-links.open { display: flex; }
    .nav-links li a { display: block; padding: .9rem 2rem; font-size: 1.0625rem; letter-spacing: .08em; color: var(--muted) !important; border-bottom: 1px solid rgba(122,108,100,0.06); }
    .nav-book { display: none; }
    .hero { grid-template-columns: 1fr; }
    .hero-right { display: none; }
    .hero-left { padding: 9rem 2.5rem 5rem; }
    .hero-bar { padding: 1.5rem 2.5rem; flex-wrap: wrap; gap: 1rem; }
    .hero-bar-divider { display: none; }
    .intro-strip, .different-section, .story-pull, .international-section { grid-template-columns: 1fr; gap: 3rem; }
    .intro-strip, .who-section, .different-section, .therapies-section, .story-pull, .process-section, .testimonials-section, .international-section, .final-cta { padding-left: 2.5rem; padding-right: 2.5rem; }
    .who-grid { grid-template-columns: 1fr; }
    .therapies-grid { grid-template-columns: 1fr 1fr; }
    .process-steps { grid-template-columns: 1fr 1fr; }
    .testimonials-grid { grid-template-columns: 1fr; }
    .regions-grid { grid-template-columns: 1fr; }
  }
</style>

<nav id="main-nav">
  <a href="/fr/" class="nav-logo" aria-label="Sara Lemaitre — Accueil">Sara Lemaitre</a>
  <ul class="nav-links" id="nav-links-list">
    <li><a href="/fr/therapies">Thérapies</a></li>
    <li><a href="/fr/workshops">Ateliers</a></li>
    <li><a href="/fr/walks">Balades</a></li>
    <li><a href="/fr/consultancy">Consultance</a></li>
    <li><a href="/fr/pricing">Tarifs</a></li>
    <li><a href="/fr/story">Mon parcours</a></li>
  </ul>
  <div style="display:flex;align-items:center;gap:.5rem;">
    <a href="/fr/book" class="nav-book">Prendre rendez-vous</a>
    <a href="/" class="lang-toggle" aria-label="Switch to English">EN</a>
    <button class="hamburger" id="hamburger-btn" aria-label="Menu" aria-expanded="false" aria-controls="nav-links-list">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-left">
    <p class="hero-eyebrow">{homepage.default.heroEyebrow}</p>
    <h1 class="hero-name">
      Sara<br>
      <em>Lemaitre</em>
