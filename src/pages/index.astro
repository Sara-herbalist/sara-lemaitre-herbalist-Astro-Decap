---
import BaseLayout from '../layouts/BaseLayout.astro';

const meta = {
  title: "Sara Lemaitre | Clinical Herbalist & Naturopath | Hormonal Health, Endometriosis, PCOS",
  description: "Clinical herbalist and naturopath specialising in endometriosis, PCOS and chronic fatigue. Former elite athlete. Online consultations in English and French, UK and international.",
  ogImage: "https://www.saralemaitre.com/images/og-home.jpg",
  canonical: "https://www.saralemaitre.com",
  navLight: false,
  currentPage: 'index',
  ogType: 'website',
};
---

<BaseLayout {...meta}>

<style is:global>
:root {
    --cream: #F7F3EE;
    --warm-white: #FDFAF7;
    --sage: #7A8C6E;
    --sage-text: #4E6245;
    --sage-light: #C4D0BA;
    --sage-pale: #EBF0E7;
    --bark: #5C4A3A;
    --bark-light: #8C7060;
    --bark-pale: #EDE5DC;
    --charcoal: #2A2420;
    --muted: #6A5E58;
    --gold: #C4A25A;
    --gold-pale: #F5EDD6;
    --plum-pale: #F0EAF0;
    --amber-pale: #FBF0E3;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--warm-white);
    color: var(--charcoal);
    font-family: 'Jost', sans-serif;
    font-size: 1.0625rem;
    font-weight: 300;
    line-height: 1.85;
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 1.5rem 4rem;
    display: flex; justify-content: space-between; align-items: center;
    background: rgba(92,74,58,0.15); /* subtle dark tint so text reads on both sides */
    backdrop-filter: blur(8px);
    border-bottom: 1px solid transparent;
    transition: background .4s, backdrop-filter .4s, border-color .4s;
  }
  nav.scrolled {
    background: rgba(253,250,247,0.96);
    backdrop-filter: blur(12px);
    border-bottom-color: rgba(122,108,100,0.1);
  }
  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem; font-weight: 400;
    letter-spacing: .12em; text-transform: uppercase;
    color: var(--cream); text-decoration: none;
    transition: color .4s;
  }
  nav.scrolled .nav-logo { color: var(--bark); }
  .nav-links { display: flex; gap: 2.5rem; list-style: none; }
  .nav-links a {
    font-size: .9375rem; letter-spacing: .14em; text-transform: uppercase;
    color: rgba(247,243,238,.85); text-decoration: none; transition: color .2s;
  }
  nav.scrolled .nav-links a { color: var(--muted); }
  .nav-links a:hover, nav.scrolled .nav-links a:hover { color: var(--bark); }
  .nav-book {
    font-size: .9375rem; letter-spacing: .16em; text-transform: uppercase;
    padding: .7rem 1.8rem;
    border: 1px solid rgba(247,243,238,.7);
    color: var(--cream); text-decoration: none;
    transition: all .3s;
  }
  nav.scrolled .nav-book {
    border-color: var(--bark);
    color: var(--bark);
  }
  .nav-book:hover { background: var(--cream); color: var(--bark); border-color: var(--cream); }
  nav.scrolled .nav-book:hover { background: var(--bark); color: var(--cream); border-color: var(--bark); }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
  }
  .hero-left {
    background: var(--bark);
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 10rem 5rem 6rem 8rem;
    position: relative; overflow: hidden;
  }
  /* large decorative letter behind hero text */
  .hero-left::before {
    content: 'S';
    position: absolute; bottom: -4rem; left: -1rem;
    font-family: 'Cormorant Garamond', serif;
    font-size: 28rem; font-weight: 300; line-height: 1;
    color: rgba(247,243,238,0.04);
    pointer-events: none;
  }
  .hero-eyebrow {
    font-size: .75rem; letter-spacing: .22em; text-transform: uppercase;
    color: var(--sage-light); margin-bottom: 2rem;
    opacity: 0; animation: fadeUp .8s .1s forwards;
    line-height: 1.6;
  }
  .hero-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.2rem, 5.5vw, 5rem);
    font-weight: 300; line-height: 1.0;
    color: var(--cream); margin-bottom: .6rem;
    opacity: 0; animation: fadeUp .8s .25s forwards;
  }
  .hero-name em { font-style: italic; color: var(--sage-light); }
  .hero-credentials {
    font-size: 1rem; letter-spacing: .06em;
    color: rgba(247,243,238,.55); margin-bottom: 3.5rem;
    opacity: 0; animation: fadeUp .8s .4s forwards;
    line-height: 2;
  }
  .hero-desc {
    font-size: 1.0625rem; color: rgba(247,243,238,.82);
    line-height: 1.9; max-width: 440px; margin-bottom: 3rem;
    opacity: 0; animation: fadeUp .8s .5s forwards;
  }
  .hero-desc strong { color: var(--cream); font-weight: 400; }
  .hero-actions {
    display: flex; gap: 1rem; flex-wrap: wrap;
    opacity: 0; animation: fadeUp .8s .65s forwards;
  }
  .btn-primary {
    display: inline-block; padding: .95rem 2.5rem;
    background: var(--sage-light); color: var(--bark);
    text-decoration: none; font-size: .9375rem;
    letter-spacing: .18em; text-transform: uppercase;
    transition: all .22s; font-weight: 400;
  }
  .btn-primary:hover { background: var(--cream); }
  .btn-ghost {
    display: inline-block; padding: .95rem 2.5rem;
    border: 1px solid rgba(247,243,238,.25);
    color: rgba(247,243,238,.6);
    text-decoration: none; font-size: .9375rem;
    letter-spacing: .18em; text-transform: uppercase;
    transition: all .22s;
  }
  .btn-ghost:hover { border-color: var(--sage-light); color: var(--sage-light); }

  .hero-right {
    background: var(--sage-pale);
    position: relative; overflow: hidden;
    display: flex; flex-direction: column; justify-content: center; align-items: center;
    opacity: 0; animation: fadeIn 1.4s .2s forwards;
  }
  /* botanical mandala */
  .hero-botanical {
    width: min(420px, 70%);
    height: min(420px, 70%);
    position: relative; z-index: 1;
  }
  /* scroll indicator */
  .scroll-hint {
    position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: .5rem;
    opacity: 0; animation: fadeIn 1s 1.4s forwards;
  }
  .scroll-hint span {
    font-size: .75rem; letter-spacing: .2em; text-transform: uppercase; color: var(--sage-text);
  }
  .scroll-line {
    width: 1px; height: 40px; background: var(--sage-light);
    animation: scrollPulse 2s 1.6s infinite;
  }
  @keyframes scrollPulse {
    0%,100% { opacity: .3; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.2); }
  }

  /* hero bottom bar */
  .hero-bar {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: rgba(92,74,58,.85);
    backdrop-filter: blur(6px);
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.2rem 8rem;
    border-top: 1px solid rgba(247,243,238,.08);
    opacity: 0; animation: fadeIn .8s 1s forwards;
    z-index: 10;
  }
  .hero-bar-item {
    display: flex; flex-direction: column; gap: .2rem;
    text-align: center;
  }
  .hero-bar-label {
    font-size: .75rem; letter-spacing: .18em; text-transform: uppercase;
    color: rgba(247,243,238,.4);
  }
  .hero-bar-value {
    font-size: 1rem; color: var(--cream); font-weight: 400;
  }
  .hero-bar-divider {
    width: 1px; height: 36px;
    background: rgba(247,243,238,.12);
  }

  /* ── INTRO STRIP ── */
  .intro-strip {
    padding: 8rem 8rem;
    display: grid; grid-template-columns: 1fr 1.6fr;
    gap: 6rem; align-items: center;
    border-bottom: 1px solid rgba(122,108,100,0.1);
  }
  .intro-strip-left {}
  .intro-strip-left .eyebrow {
    font-size: .75rem; letter-spacing: .22em; text-transform: uppercase;
    color: var(--sage-text); margin-bottom: 1.5rem;
  }
  .intro-strip-left h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.2rem, 3.5vw, 3.2rem);
    font-weight: 300; color: var(--bark);
    line-height: 1.15;
  }
  .intro-strip-left h2 em { font-style: italic; color: var(--sage-text); }
  .intro-strip-right p {
    font-size: 1.0625rem; color: #4A403C;
    line-height: 2; margin-bottom: 1.4rem;
  }
  .intro-strip-right p:last-child { margin-bottom: 0; }
  .intro-strip-right p strong { font-weight: 500; color: var(--bark); }
  .read-more {
    display: inline-flex; align-items: center; gap: .6rem;
    margin-top: 1.8rem;
    font-size: .9375rem; letter-spacing: .16em; text-transform: uppercase;
    color: var(--sage-text); text-decoration: none; transition: color .2s;
  }
  .read-more:hover { color: var(--bark); }
  .read-more::after {
    content: '→'; font-size: 1.0625rem; transition: transform .2s;
  }
  .read-more:hover::after { transform: translateX(4px); }

  /* ── WHO I HELP ── */
  .who-section {
    background: var(--cream);
    padding: 8rem;
    border-bottom: 1px solid rgba(122,108,100,0.1);
  }
  .who-header {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 4rem; margin-bottom: 5rem; align-items: end;
  }
  .who-header h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.2rem, 3.5vw, 3rem);
    font-weight: 300; color: var(--bark); line-height: 1.15;
  }
  .who-header h2 em { font-style: italic; color: var(--sage-text); }
  .who-header-desc {
    font-size: 1.0625rem; color: var(--muted);
    line-height: 1.95;
    border-left: 2px solid var(--sage-light);
    padding-left: 1.5rem;
  }
  .who-grid {
    display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 1.5px;
    background: rgba(122,108,100,0.12);
  }
  .who-card {
    background: var(--warm-white);
    padding: 3rem 2.5rem;
    transition: background .22s;
    cursor: default;
  }
  .who-card:hover { background: var(--sage-pale); }
  .who-card-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3rem; font-weight: 300; color: var(--sage-light);
    line-height: 1; margin-bottom: 1.2rem;
  }
  .who-card-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem; font-weight: 400; color: var(--bark);
    margin-bottom: .8rem; line-height: 1.2;
  }
  .who-card-desc {
    font-size: 1rem; color: var(--muted);
    line-height: 1.8;
  }
  .who-card-tags {
    margin-top: 1.2rem; display: flex; flex-wrap: wrap; gap: .4rem;
  }
  .who-tag {
    font-size: .9375rem; padding: .25rem .8rem;
    background: var(--cream); color: var(--bark-light);
    border: 1px solid rgba(122,108,100,0.2);
    border-radius: 20px;
  }

  /* ── WHAT MAKES ME DIFFERENT ── */
  .different-section {
    padding: 8rem;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 8rem; align-items: center;
    border-bottom: 1px solid rgba(122,108,100,0.1);
  }
  .different-left .eyebrow {
    font-size: .75rem; letter-spacing: .22em; text-transform: uppercase;
    color: var(--sage-text); margin-bottom: 1.5rem;
  }
  .different-left h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.2rem, 3.2vw, 3rem);
    font-weight: 300; color: var(--bark); line-height: 1.15;
    margin-bottom: 2.5rem;
  }
  .different-left h2 em { font-style: italic; color: var(--sage-text); }
  .different-left p {
    font-size: 1.0625rem; color: #4A403C;
    line-height: 1.95; margin-bottom: 1.3rem;
  }
  .different-right {
    display: flex; flex-direction: column; gap: 0;
  }
  .diff-item {
    padding: 2rem 0;
    border-bottom: 1px solid rgba(122,108,100,0.12);
    display: grid; grid-template-columns: 44px 1fr; gap: 1.2rem;
    align-items: flex-start;
  }
  .diff-item:first-child { border-top: 1px solid rgba(122,108,100,0.12); }
  .diff-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem; font-weight: 300; color: var(--sage-light);
    line-height: 1; padding-top: .2rem;
  }
  .diff-text-title {
    font-size: 1.0625rem; font-weight: 500; color: var(--bark);
    margin-bottom: .3rem;
  }
  .diff-text-body {
    font-size: 1rem; color: var(--muted); line-height: 1.75;
  }

  /* ── FEATURED THERAPIES ── */
  .therapies-section {
    background: var(--bark);
    padding: 8rem;
    border-bottom: 1px solid rgba(122,108,100,0.1);
  }
  .therapies-header {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 4rem;
  }
  .therapies-header h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3vw, 2.8rem);
    font-weight: 300; color: var(--cream); line-height: 1.15;
  }
  .therapies-header h2 em { font-style: italic; color: var(--sage-light); }
  .therapies-header a {
    font-size: .9375rem; letter-spacing: .16em; text-transform: uppercase;
    color: var(--sage-light); text-decoration: none; transition: color .2s;
    white-space: nowrap;
  }
  .therapies-header a:hover { color: var(--cream); }
  .therapies-grid {
    display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 1px;
    background: rgba(247,243,238,.06);
  }
  .therapy-card {
    background: var(--bark);
    padding: 2.5rem 2rem;
    border: 1px solid rgba(247,243,238,.07);
    text-decoration: none;
    transition: background .22s;
    display: flex; flex-direction: column;
  }
  .therapy-card:hover { background: rgba(247,243,238,.05); }
  .therapy-card-icon {
    width: 48px; height: 48px; margin-bottom: 1.8rem; opacity: .6;
  }
  .therapy-card-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.35rem; font-weight: 400; color: var(--cream);
    margin-bottom: .6rem; line-height: 1.2;
  }
  .therapy-card-desc {
    font-size: 1rem; color: rgba(247,243,238,.5);
    line-height: 1.75; flex: 1;
  }
  .therapy-card-link {
    margin-top: 1.5rem; font-size: .75rem; letter-spacing: .14em;
    text-transform: uppercase; color: var(--sage-light);
    display: flex; align-items: center; gap: .4rem;
    transition: gap .2s;
  }
  .therapy-card:hover .therapy-card-link { gap: .7rem; }

  /* ── STORY PULL ── */
  .story-pull {
    display: grid; grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid rgba(122,108,100,0.1);
  }
  .story-pull-text {
    padding: 8rem;
    background: var(--warm-white);
    display: flex; flex-direction: column; justify-content: center;
  }
  .story-pull-text .eyebrow {
    font-size: .75rem; letter-spacing: .22em; text-transform: uppercase;
    color: var(--sage-text); margin-bottom: 1.5rem;
  }
  .story-pull-text h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3vw, 2.8rem);
    font-weight: 300; color: var(--bark); line-height: 1.2;
    margin-bottom: 2rem;
  }
  .story-pull-text h2 em { font-style: italic; color: var(--sage-text); }
  .story-pull-text p {
    font-size: 1.0625rem; color: #4A403C;
    line-height: 1.95; margin-bottom: 1.3rem; max-width: 480px;
  }
  .story-pull-text .btn-bark {
    display: inline-block; margin-top: .8rem;
    padding: .9rem 2.4rem;
    border: 1px solid var(--bark); color: var(--bark);
    text-decoration: none; font-size: .9375rem;
    letter-spacing: .18em; text-transform: uppercase;
    transition: all .22s; align-self: flex-start;
  }
  .story-pull-text .btn-bark:hover { background: var(--bark); color: var(--warm-white); }
  .story-pull-visual {
    background: var(--bark-pale);
    position: relative; overflow: hidden;
    display: flex; align-items: center; justify-content: center;
    padding: 4rem;
  }
  .story-pull-visual::after {
    content: '"';
    position: absolute; top: 2rem; left: 3rem;
    font-family: 'Cormorant Garamond', serif;
    font-size: 12rem; line-height: 1; font-weight: 300;
    color: var(--sage-light); opacity: .2;
    pointer-events: none;
  }
  .story-quote {
    position: relative; z-index: 1;
    max-width: 400px; text-align: center;
  }
  .story-quote p {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem; font-style: italic; font-weight: 300;
    color: var(--bark); line-height: 1.6; margin-bottom: 1.5rem;
  }
  .story-quote cite {
    font-size: .75rem; letter-spacing: .16em; text-transform: uppercase;
    color: var(--muted);
  }

  /* ── PROCESS ── */
  .process-section {
    background: var(--cream);
    padding: 8rem;
    border-bottom: 1px solid rgba(122,108,100,0.1);
  }
  .process-header {
    text-align: center; margin-bottom: 5rem;
  }
  .process-header .eyebrow {
    font-size: .75rem; letter-spacing: .22em; text-transform: uppercase;
    color: var(--sage-text); margin-bottom: 1.2rem;
  }
  .process-header h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3vw, 2.8rem);
    font-weight: 300; color: var(--bark); line-height: 1.2;
  }
  .process-header h2 em { font-style: italic; color: var(--sage-text); }
  .process-steps {
    display: grid; grid-template-columns: repeat(4, minmax(0,1fr));
    gap: 0; position: relative;
  }
  .process-steps::before {
    content: '';
    position: absolute; top: 28px; left: calc(12.5%); right: calc(12.5%);
    height: 1px; background: var(--sage-light); opacity: .5;
    z-index: 0;
  }
  .process-step {
    padding: 0 2rem;
    display: flex; flex-direction: column; align-items: center;
    text-align: center; position: relative; z-index: 1;
  }
  .process-dot {
    width: 56px; height: 56px; border-radius: 50%;
    background: var(--warm-white);
    border: 1px solid var(--sage-light);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1.8rem;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem; font-weight: 300; color: var(--sage-text);
  }
  .process-step-title {
    font-size: 1rem; font-weight: 500; color: var(--bark);
    margin-bottom: .6rem;
  }
  .process-step-desc {
    font-size: 1rem; color: var(--muted); line-height: 1.75;
  }

  /* ── TESTIMONIALS ── */
  .testimonials-section {
    padding: 8rem;
    border-bottom: 1px solid rgba(122,108,100,0.1);
  }
  .testimonials-header { margin-bottom: 4rem; }
  .testimonials-header .eyebrow {
    font-size: .75rem; letter-spacing: .22em; text-transform: uppercase;
    color: var(--sage-text); margin-bottom: 1.2rem;
  }
  .testimonials-header h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3vw, 2.6rem);
    font-weight: 300; color: var(--bark); line-height: 1.2;
  }
  .testimonials-header h2 em { font-style: italic; color: var(--sage-text); }
  .testimonials-grid {
    display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 2rem;
  }
  .testimonial-card {
    padding: 2.5rem;
    border: 1px solid rgba(122,108,100,0.12);
    background: var(--warm-white);
    position: relative;
  }
  .testimonial-card::before {
    content: '"';
    position: absolute; top: 1.5rem; left: 2rem;
    font-family: 'Cormorant Garamond', serif;
    font-size: 4rem; line-height: 1; font-weight: 300;
    color: var(--sage-light); opacity: .4; pointer-events: none;
  }
  .testimonial-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.125rem; font-style: italic;
    color: var(--bark); line-height: 1.7;
    padding-top: 1.2rem; margin-bottom: 1.5rem;
  }
  .testimonial-author {
    font-size: .9375rem; letter-spacing: .12em; text-transform: uppercase;
    color: var(--muted);
  }
  .testimonial-condition {
    font-size: .9375rem; color: var(--sage-text); margin-top: .2rem;
  }
  /* placeholder style */
  .testimonial-card.placeholder { opacity: .5; border-style: dashed; }
  .testimonial-card.placeholder .testimonial-text { font-style: normal; font-size: 1.0625rem; font-family: 'Jost', sans-serif; }

  /* ── INTERNATIONAL ── */
  .international-section {
    background: var(--sage);
    padding: 7rem 8rem;
    display: grid; grid-template-columns: 1.2fr 1fr;
    gap: 6rem; align-items: center;
    border-bottom: 1px solid rgba(122,108,100,0.1);
  }
  .international-text .eyebrow {
    font-size: .75rem; letter-spacing: .22em; text-transform: uppercase;
    color: var(--sage-pale); margin-bottom: 1.5rem;
  }
  .international-text h2 {
    font-family: 'Cormorant Garamond', serif;
