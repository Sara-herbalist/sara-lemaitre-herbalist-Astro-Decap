---
import BaseLayout from '../layouts/BaseLayout.astro';

const p = (await import('../data/pricing.json')).default;
const CALENDLY = 'https://calendly.com/sara-lemaitre-herbalist';
const meta = {
  title: "Pricing & Packages | Herbal Medicine Consultations from £60 | Sara Lemaitre",
  description: "Transparent pricing for herbal medicine consultations from £60. Initial consultation £110, follow-up £75, bundle of 3 sessions £220. Sliding scale available. Indian head massage £60.",
  ogImage: "https://www.saralemaitre.com/images/og-pricing.jpg",
  canonical: "https://www.saralemaitre.com/pricing",
  navLight: false,
  currentPage: 'pricing',
  ogType: 'website',
};
---

<BaseLayout {...meta}>

<style is:global>
:root {
    --cream: #F7F3EE;
    --warm-white: #FDFAF7;
    --sage: #7A8C6E;
    --sage-text: #4E6245;
    --sage-light: #C4D0BA;
    --sage-pale: #EBF0E7;
    --bark: #5C4A3A;
    --bark-light: #8C7060;
    --bark-pale: #EDE5DC;
    --charcoal: #2A2420;
    --muted: #6A5E58;
    --gold: #C4A25A;
    --gold-pale: #F5EDD6;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--warm-white);
    color: var(--charcoal);
    font-family: 'Jost', sans-serif;
    font-size: 1.0625rem;
    font-weight: 300;
    line-height: 1.85;
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 1.5rem 4rem;
    display: flex; justify-content: space-between; align-items: center;
    background: rgba(253,250,247,0.93);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(122,108,100,0.1);
  }
  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem; font-weight: 400; letter-spacing: .12em;
    text-transform: uppercase; color: var(--bark); text-decoration: none;
  }
  .nav-links { display: flex; gap: 2.5rem; list-style: none; }
  .nav-links a {
    font-size: .9375rem; letter-spacing: .14em; text-transform: uppercase;
    color: var(--muted); text-decoration: none; transition: color .2s;
  }
  .nav-links a:hover { color: var(--bark); }
  .nav-links a.active { color: var(--bark); }
  .nav-book {
    font-size: .9375rem; letter-spacing: .16em; text-transform: uppercase;
    padding: .7rem 1.8rem; border: 1px solid var(--bark);
    color: var(--bark); text-decoration: none; transition: all .22s;
  }
  .nav-book:hover { background: var(--bark); color: var(--warm-white); }

  /* ── PAGE HEADER ── */
  .page-header {
    padding: 14rem 8rem 7rem;
    background: var(--bark);
    position: relative; overflow: hidden;
  }
  .page-header::before {
    content: '£';
    position: absolute; right: -2rem; bottom: -4rem;
    font-family: 'Cormorant Garamond', serif;
    font-size: 30rem; font-weight: 300; line-height: 1;
    color: rgba(247,243,238,0.04); pointer-events: none;
  }
  .header-eyebrow {
    font-size: .875rem; letter-spacing: .24em; text-transform: uppercase;
    color: var(--sage-light); margin-bottom: 1.8rem;
    opacity: 0; animation: fadeUp .7s .2s forwards;
  }
  .header-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3rem, 5.5vw, 5rem);
    font-weight: 300; line-height: 1.05; color: var(--cream);
    margin-bottom: 2rem; max-width: 700px;
    opacity: 0; animation: fadeUp .7s .35s forwards;
  }
  .header-title em { font-style: italic; color: var(--sage-light); }
  .header-desc {
    font-size: 1.0625rem; color: rgba(247,243,238,.6);
    line-height: 1.95; max-width: 580px;
    opacity: 0; animation: fadeUp .7s .5s forwards;
  }
  .header-desc strong { color: var(--cream); font-weight: 400; }

  /* ── PHILOSOPHY BAR ── */
  .philosophy-bar {
    background: var(--cream);
    padding: 4rem 8rem;
    border-bottom: 1px solid rgba(122,108,100,0.12);
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 5rem; align-items: center;
  }
  .philosophy-bar h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.6rem, 2.5vw, 2.2rem);
    font-weight: 300; color: var(--bark); line-height: 1.3;
  }
  .philosophy-bar h2 em { font-style: italic; color: var(--sage-text); }
  .philosophy-bar p {
    font-size: 1rem; color: var(--muted); line-height: 1.9;
  }

  /* ── SECTION LABEL ── */
  .section-label {
    padding: 3rem 8rem 1.5rem;
    display: flex; align-items: center; gap: 1.5rem;
  }
  .section-label-text {
    font-size: .75rem; letter-spacing: .24em; text-transform: uppercase; color: var(--sage-text);
  }
  .section-label-line {
    flex: 1; height: 1px; background: rgba(122,108,100,0.15);
  }

  /* ── CONSULTATIONS ══ */
  .consultations-block {
    padding: 1rem 8rem 5rem;
    border-bottom: 1px solid rgba(122,108,100,0.1);
  }
  .consult-grid {
    display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 1.5px;
    background: rgba(122,108,100,0.12); margin-bottom: 1.5px;
  }
  .consult-card {
    background: var(--warm-white);
    padding: 3rem 2.5rem;
    position: relative;
  }
  .consult-card.featured {
    background: var(--sage-pale);
    border-top: 3px solid var(--sage);
  }
  .featured-badge {
    position: absolute; top: -1px; left: 2.5rem;
    background: var(--sage); color: var(--warm-white);
    font-size: .75rem; letter-spacing: .16em; text-transform: uppercase;
    padding: .3rem .9rem;
  }
  .consult-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem; font-weight: 400; color: var(--bark);
    margin-bottom: .5rem; margin-top: .5rem; line-height: 1.2;
  }
  .consult-subtitle {
    font-size: .9375rem; color: var(--muted); margin-bottom: 2rem;
  }
  .consult-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3.2rem; font-weight: 300; color: var(--bark);
    line-height: 1; margin-bottom: .4rem;
  }
  .sliding-note {
  font-size: .8rem;
  color: var(--sage-text);
  background: var(--sage-pale);
  border-left: 2px solid var(--sage-light);
  padding: .4rem .7rem;
  margin: .5rem 0;
  font-style: italic;
  line-height: 1.5;
}
.consult-price-note {
    font-size: .9375rem; color: var(--muted); margin-bottom: 2.2rem;
  }
  .consult-includes {
    list-style: none; display: flex; flex-direction: column; gap: .65rem;
    margin-bottom: 2.5rem;
  }
  .consult-includes li {
    font-size: .87rem; color: #4A403C;
    display: flex; align-items: flex-start; gap: .7rem; line-height: 1.5;
  }
  .consult-includes li::before {
    content: '·'; color: var(--sage-text); flex-shrink: 0; font-size: 1.1rem; line-height: 1.3;
  }
  .consult-book {
    display: inline-block; padding: .85rem 2rem;
    border: 1px solid var(--bark); color: var(--bark);
    text-decoration: none; font-size: .9375rem;
    letter-spacing: .16em; text-transform: uppercase;
    transition: all .22s;
  }
  .consult-book:hover { background: var(--bark); color: var(--warm-white); }
  .consult-card.featured .consult-book {
    background: var(--bark); color: var(--warm-white); border-color: var(--bark);
  }
  .consult-card.featured .consult-book:hover { background: var(--charcoal); }

  /* free discovery row */
  .free-row {
    background: var(--bark);
    padding: 2.5rem 3rem;
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 1.5rem;
  }
  .free-row-left { display: flex; flex-direction: column; gap: .3rem; }
  .free-row-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem; font-weight: 300; color: var(--cream);
  }
  .free-row-subtitle { font-size: 1rem; color: rgba(247,243,238,.55); }
  .free-row-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem; font-weight: 300; color: var(--sage-light);
    text-align: center; min-width: 80px;
  }
  .free-row-includes {
    font-size: 1rem; color: rgba(247,243,238,.55);
    flex: 1; min-width: 200px;
    padding: 0 2rem;
    border-left: 1px solid rgba(247,243,238,.1);
    border-right: 1px solid rgba(247,243,238,.1);
  }
  .free-book {
    display: inline-block; padding: .85rem 2rem;
    background: var(--sage-light); color: var(--bark);
    text-decoration: none; font-size: .9375rem;
    letter-spacing: .16em; text-transform: uppercase;
    transition: all .22s; flex-shrink: 0;
  }
  .free-book:hover { background: var(--cream); }

  /* ── PACKAGES ══ */
  .packages-block {
    padding: 1rem 8rem 5rem;
    border-bottom: 1px solid rgba(122,108,100,0.1);
  }
  .packages-intro {
    max-width: 640px; margin-bottom: 3.5rem;
    font-size: 1.0625rem; color: #4A403C; line-height: 1.95;
  }
  .packages-grid {
    display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 2rem;
  }
  .package-card {
    padding: 3rem;
    border: 1px solid rgba(122,108,100,0.15);
    background: var(--warm-white);
    position: relative; transition: border-color .2s;
  }
  .package-card:hover { border-color: var(--sage-text); }
  .package-card.highlight {
    border-color: var(--sage-text);
    background: var(--sage-pale);
  }
  .package-badge {
    display: inline-block;
    background: var(--sage); color: var(--warm-white);
    font-size: .75rem; letter-spacing: .16em; text-transform: uppercase;
    padding: .3rem .9rem; margin-bottom: 1.5rem;
  }
  .package-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem; font-weight: 300; color: var(--bark);
    margin-bottom: .5rem; line-height: 1.15;
  }
  .package-name em { font-style: italic; color: var(--sage-text); }
  .package-tagline {
    font-size: 1rem; color: var(--muted); margin-bottom: 2rem; line-height: 1.6;
  }
  .package-price-row {
    display: flex; align-items: baseline; gap: .8rem;
    margin-bottom: .5rem;
  }
  .package-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3rem; font-weight: 300; color: var(--bark);
  }
  .package-saving {
    font-size: .9375rem; color: var(--sage-text);
    padding: .2rem .7rem;
    border: 1px solid rgba(122,140,110,0.4);
    border-radius: 20px;
  }
  .package-vs {
    font-size: .9375rem; color: var(--muted); margin-bottom: 2.2rem;
    text-decoration: line-through;
  }
  .package-sessions {
    font-size: 1rem; font-weight: 500; color: var(--bark);
    letter-spacing: .06em; margin-bottom: 1.2rem; text-transform: uppercase;
  }
  .package-includes {
    list-style: none; display: flex; flex-direction: column; gap: .6rem;
    margin-bottom: 2.5rem; padding-bottom: 2rem;
    border-bottom: 1px solid rgba(122,108,100,0.12);
  }
  .package-includes li {
    font-size: .87rem; color: #4A403C;
    display: flex; align-items: flex-start; gap: .7rem; line-height: 1.5;
  }
  .package-includes li::before {
    content: '✓'; color: var(--sage-text); flex-shrink: 0; font-size: 1rem; margin-top: .1rem;
  }
  .package-who {
    font-size: 1rem; color: var(--muted);
    line-height: 1.7; margin-bottom: 2rem;
  }
  .package-who strong { color: var(--bark); font-weight: 500; }
  .package-book {
    display: inline-block; padding: .85rem 2rem;
    border: 1px solid var(--bark); color: var(--bark);
    text-decoration: none; font-size: .9375rem;
    letter-spacing: .16em; text-transform: uppercase;
    transition: all .22s;
  }
  .package-book:hover, .package-card.highlight .package-book {
    background: var(--bark); color: var(--warm-white);
  }

  /* ── RETAINER ══ */
  .retainer-block {
    padding: 1rem 8rem 5rem;
    border-bottom: 1px solid rgba(122,108,100,0.1);
  }
  .retainer-card {
    background: var(--bark);
    padding: 4rem 5rem;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 5rem; align-items: center;
  }
  .retainer-left .eyebrow {
    font-size: .75rem; letter-spacing: .22em; text-transform: uppercase;
    color: var(--sage-light); margin-bottom: 1.5rem;
  }
  .retainer-left h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3vw, 2.8rem);
    font-weight: 300; color: var(--cream); line-height: 1.2;
    margin-bottom: 1.8rem;
  }
  .retainer-left h2 em { font-style: italic; color: var(--sage-light); }
  .retainer-left p {
    font-size: 1rem; color: rgba(247,243,238,.65);
    line-height: 1.9; margin-bottom: 1.2rem;
  }
  .retainer-right { display: flex; flex-direction: column; gap: 0; }
  .retainer-option {
    padding: 2rem 0;
    border-bottom: 1px solid rgba(247,243,238,.08);
    display: flex; justify-content: space-between; align-items: flex-start; gap: 2rem;
  }
  .retainer-option:first-child { border-top: 1px solid rgba(247,243,238,.08); }
  .retainer-option-name {
    font-size: 1.0625rem; font-weight: 400; color: var(--cream);
    margin-bottom: .3rem;
  }
  .retainer-option-desc {
    font-size: 1rem; color: rgba(247,243,238,.45); line-height: 1.6;
  }
  .retainer-option-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem; font-weight: 300; color: var(--sage-light);
    white-space: nowrap; flex-shrink: 0;
  }
  .retainer-option-period {
    font-size: .875rem; color: rgba(247,243,238,.35);
    display: block; text-align: right;
  }
  .retainer-book {
    display: inline-block; margin-top: 2rem;
    padding: .9rem 2.2rem;
    border: 1px solid var(--sage-light); color: var(--sage-light);
    text-decoration: none; font-size: .9375rem;
    letter-spacing: .18em; text-transform: uppercase;
    transition: all .22s;
  }
  .retainer-book:hover { background: var(--sage-light); color: var(--bark); }

  /* ── IN PERSON ══ */
  .inperson-block {
    padding: 1rem 8rem 5rem;
    border-bottom: 1px solid rgba(122,108,100,0.1);
  }
  .inperson-grid {
    display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 1.5px;
    background: rgba(122,108,100,0.12);
  }
  .inperson-card {
    background: var(--warm-white); padding: 2.8rem;
  }
  .inperson-card.alt { background: var(--bark-pale); }
  .inperson-tag {
    font-size: .75rem; letter-spacing: .18em; text-transform: uppercase;
    color: var(--sage-text); margin-bottom: 1rem;
  }
  .inperson-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem; font-weight: 400; color: var(--bark);
    margin-bottom: .5rem; line-height: 1.2;
  }
  .inperson-subtitle {
    font-size: 1rem; color: var(--muted); margin-bottom: 1.8rem;
  }
  .inperson-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.6rem; font-weight: 300; color: var(--bark);
    line-height: 1; margin-bottom: .4rem;
  }
  .inperson-price-note { font-size: .9375rem; color: var(--muted); margin-bottom: 1.8rem; }
  .inperson-desc { font-size: .87rem; color: #4A403C; line-height: 1.8; margin-bottom: 1.5rem; }
  .inperson-book {
    display: inline-block; padding: .75rem 1.8rem;
    border: 1px solid var(--bark); color: var(--bark);
    text-decoration: none; font-size: .875rem;
    letter-spacing: .16em; text-transform: uppercase; transition: all .22s;
  }
  .inperson-book:hover { background: var(--bark); color: var(--warm-white); }

  /* ── PRODUCTS PRICING ── */
  .products-pricing {
    padding: 1rem 8rem 5rem;
    border-bottom: 1px solid rgba(122,108,100,0.1);
  }
  .products-pricing-intro {
    font-size: 1.0625rem; color: #4A403C; line-height: 1.95;
    max-width: 580px; margin-bottom: 3rem;
  }
  .products-table {
    width: 100%; border-collapse: collapse;
  }
  .products-table th {
    font-size: .75rem; letter-spacing: .18em; text-transform: uppercase;
    color: var(--sage-text); font-weight: 400; padding: 1rem 1.5rem;
    border-bottom: 1px solid rgba(122,108,100,0.15);
    text-align: left;
  }
  .products-table td {
    padding: 1.2rem 1.5rem;
    border-bottom: 1px solid rgba(122,108,100,0.08);
    font-size: .87rem;
  }
  .products-table tr:last-child td { border-bottom: none; }
  .products-table tr:hover td { background: var(--cream); }
  .product-name { font-weight: 400; color: var(--bark); }
  .product-desc { color: var(--muted); line-height: 1.5; font-size: 1rem; }
  .product-price { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; color: var(--bark); white-space: nowrap; }
  .product-note { font-size: .9375rem; color: var(--sage-text); }

  /* ── FAQ ── */
  .faq-block {
    padding: 5rem 8rem;
    background: var(--cream);
    border-bottom: 1px solid rgba(122,108,100,0.1);
  }
  .faq-header { margin-bottom: 3.5rem; }
  .faq-header .eyebrow {
    font-size: .75rem; letter-spacing: .22em; text-transform: uppercase;
    color: var(--sage-text); margin-bottom: 1.2rem;
  }
  .faq-header h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.8rem, 2.5vw, 2.4rem);
    font-weight: 300; color: var(--bark); line-height: 1.2;
  }
  .faq-header h2 em { font-style: italic; color: var(--sage-text); }
  .faq-list { display: flex; flex-direction: column; max-width: 720px; }
  .faq-item {
    border-top: 1px solid rgba(122,108,100,0.15);
    padding: 0;
    overflow: hidden;
  }
  .faq-item:last-child { border-bottom: 1px solid rgba(122,108,100,0.15); }
  .faq-question {
    width: 100%; background: none; border: none; cursor: pointer;
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.4rem 0; gap: 1rem;
    font-family: 'Jost', sans-serif; font-weight: 400; font-size: 1.0625rem;
    color: var(--bark); text-align: left;
    transition: color .2s;
  }
  .faq-question:hover { color: var(--sage-text); }
  .faq-icon {
    width: 20px; height: 20px; flex-shrink: 0;
    border: 1px solid rgba(122,108,100,0.3); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem; color: var(--sage-text);
    transition: transform .25s, background .2s;
  }
  .faq-item.open .faq-icon { transform: rotate(45deg); background: var(--sage); color: var(--warm-white); border-color: var(--sage-text); }
  .faq-answer {
    max-height: 0; overflow: hidden;
    transition: max-height .35s ease, padding .35s ease;
  }
  .faq-item.open .faq-answer { max-height: 400px; }
  .faq-answer p {
    font-size: .87rem; color: var(--muted);
    line-height: 1.9; padding-bottom: 1.5rem;
  }

  /* ── FINAL CTA ── */
  .final-cta {
    padding: 8rem;
    text-align: center; background: var(--warm-white);
    position: relative; overflow: hidden;
  }
  .final-cta::before {
    content: 'Begin';
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'Cormorant Garamond', serif;
    font-size: 20rem; font-weight: 300;
    color: var(--sage-light); opacity: .05;
    pointer-events: none; white-space: nowrap;
  }
  .final-cta .eyebrow {
    font-size: .75rem; letter-spacing: .22em; text-transform: uppercase;
    color: var(--sage-text); margin-bottom: 1.5rem; position: relative;
  }
  .final-cta h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    font-weight: 300; color: var(--bark);
    line-height: 1.2; margin-bottom: 1.5rem; position: relative;
  }
  .final-cta h2 em { font-style: italic; color: var(--sage-text); }
  .final-cta p {
    font-size: 1.0625rem; color: var(--muted);
    line-height: 1.9; max-width: 500px; margin: 0 auto 3rem;
    position: relative;
  }
  .cta-buttons { display: flex; gap: 1.2rem; justify-content: center; flex-wrap: wrap; position: relative; }
  .cta-btn-primary {
    display: inline-block; padding: 1.05rem 2.8rem;
    background: var(--bark); color: var(--cream);
    text-decoration: none; font-size: .9375rem;
    letter-spacing: .18em; text-transform: uppercase; transition: all .22s;
  }
  .cta-btn-primary:hover { background: var(--charcoal); }
  .cta-btn-secondary {
    display: inline-block; padding: 1.05rem 2.8rem;
    border: 1px solid rgba(92,74,58,.3); color: var(--bark-light);
    text-decoration: none; font-size: .9375rem;
