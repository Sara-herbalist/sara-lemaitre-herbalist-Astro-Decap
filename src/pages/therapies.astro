---
import BaseLayout from '../layouts/BaseLayout.astro';
const s = (await import('../data/settings.json')).default;
const d = (await import('../data/therapies.json')).default;
const meta = {
  title: "Therapies | Herbal Medicine, Naturopathy & Indian Head Massage | Sara Lemaitre",
  description: "Clinical herbal medicine, naturopathy, Indian head massage and athlete performance support. Online and in person. English and French.",
  ogImage: "https://www.saralemaitre.com/images/og-therapies.jpg",
  canonical: "https://www.saralemaitre.com/therapies",
  navLight: false,
  currentPage: 'therapies',
  ogType: 'website',
};
---
<BaseLayout {...meta}>
<style is:global>
:root{--cream:#F7F3EE;--warm-white:#FDFAF7;--sage:#7A8C6E;--sage-text:#4E6245;--sage-light:#C4D0BA;--sage-pale:#EBF0E7;--bark:#5C4A3A;--bark-light:#8C7060;--bark-pale:#EDE5DC;--charcoal:#2A2420;--muted:#6A5E58}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--warm-white);color:var(--charcoal);font-family:'Jost',sans-serif;font-size:1.0625rem;font-weight:300;line-height:1.85;overflow-x:hidden}
.th-hero{padding:10rem 8rem 7rem;background:var(--cream);border-bottom:1px solid rgba(92,74,58,0.08)}
.th-hero .eyebrow{font-size:.75rem;letter-spacing:.22em;text-transform:uppercase;color:var(--sage-text);margin-bottom:1.5rem}
.th-hero h1{font-family:'Cormorant Garamond',serif;font-size:clamp(2.8rem,5vw,4.5rem);font-weight:400;line-height:1.1;color:var(--charcoal);margin-bottom:1.5rem}
.th-hero h1 em{font-style:italic;color:var(--sage-text)}
.th-hero p{font-size:1.125rem;color:var(--muted);max-width:600px;line-height:1.85}
.therapy-block{padding:7rem 8rem;display:grid;grid-template-columns:1fr 1.5fr;gap:6rem;align-items:start;border-bottom:1px solid rgba(122,108,100,0.1)}
.therapy-block:nth-child(even){background:var(--cream);grid-template-columns:1.5fr 1fr}
.therapy-block:nth-child(even) .therapy-meta{order:2}
.therapy-block:nth-child(even) .therapy-content{order:1}
.therapy-label{font-size:.75rem;letter-spacing:.22em;text-transform:uppercase;color:var(--sage-text);margin-bottom:1rem}
.therapy-block h2{font-family:'Cormorant Garamond',serif;font-size:clamp(1.8rem,3vw,2.4rem);font-weight:400;color:var(--charcoal);line-height:1.2;margin-bottom:1.5rem}
.therapy-meta-details{display:flex;flex-direction:column;gap:.75rem;margin-bottom:1.5rem}
.therapy-detail-row{display:flex;gap:1rem;align-items:baseline}
.therapy-detail-label{font-size:.75rem;letter-spacing:.14em;text-transform:uppercase;color:var(--sage-text);min-width:80px}
.therapy-detail-value{font-size:.9375rem;color:var(--muted)}
.therapy-block p{font-size:1.0625rem;color:var(--muted);line-height:1.95;margin-bottom:1.2rem}
.therapy-block-photo{margin-bottom:2rem;overflow:hidden}
.therapy-block-photo img{width:100%;height:260px;object-fit:cover;filter:brightness(0.88) saturate(0.85)}
.therapy-book{display:inline-block;padding:.85rem 2rem;border:1px solid var(--bark);color:var(--bark);text-decoration:none;font-size:.875rem;letter-spacing:.14em;text-transform:uppercase;transition:all .22s;margin-top:1rem}
.therapy-book:hover{background:var(--bark);color:var(--warm-white)}
.plant-strip{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;background:var(--charcoal)}
.plant-strip-item{aspect-ratio:3/2;overflow:hidden}
.plant-strip-item img{width:100%;height:100%;object-fit:cover;filter:brightness(0.8) saturate(0.7);transition:all .5s ease}
.plant-strip-item:hover img{filter:brightness(1) saturate(1);transform:scale(1.04)}
.th-cta{padding:7rem 8rem;background:var(--sage);text-align:center}
.th-cta h2{font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,3.5vw,3rem);font-weight:400;color:var(--cream);margin-bottom:1rem}
.th-cta p{color:rgba(247,243,238,.6);margin-bottom:2.5rem}
.th-cta a{display:inline-block;padding:1.1rem 3rem;background:var(--bark);color:var(--cream);text-decoration:none;font-size:.9375rem;letter-spacing:.18em;text-transform:uppercase;transition:all .22s}
.th-cta a:hover{background:var(--charcoal)}
.reveal{opacity:0;transform:translateY(24px);transition:opacity .75s ease,transform .75s ease}
.reveal.visible{opacity:1;transform:translateY(0)}
@media(max-width:1024px){
  .th-hero,.therapy-block,.th-cta{padding-left:2.5rem;padding-right:2.5rem}
  .therapy-block,.therapy-block:nth-child(even){grid-template-columns:1fr;gap:3rem}
  .therapy-block:nth-child(even) .therapy-meta,.therapy-block:nth-child(even) .therapy-content{order:unset}
  .plant-strip{grid-template-columns:1fr 1fr}
}
</style>

<section class="th-hero">
  <p class="eyebrow">Therapies</p>
  <h1 set:html={d.pageTitle}></h1>
  <p>{d.pageDesc}</p>
</section>

{d.therapyBlocks && d.therapyBlocks.map((therapy, i) => (
  <section class={`therapy-block reveal`} id={therapy.id}>
    <div class="therapy-meta">
      {therapy.photo && !therapy.photo.includes('placeholder') && therapy.photo !== `/images/${therapy.id}.jpg` && (
        <div class="therapy-block-photo">
          <img src={therapy.photo} alt={therapy.title} />
        </div>
      )}
      <p class="therapy-label">{therapy.label}</p>
      <h2>{therapy.title}</h2>
      <div class="therapy-meta-details">
        {therapy.duration && <div class="therapy-detail-row"><span class="therapy-detail-label">Duration</span><span class="therapy-detail-value">{therapy.duration}</span></div>}
        {therapy.format && <div class="therapy-detail-row"><span class="therapy-detail-label">Format</span><span class="therapy-detail-value">{therapy.format}</span></div>}
        {therapy.price && <div class="therapy-detail-row"><span class="therapy-detail-label">Price</span><span class="therapy-detail-value">{therapy.price}</span></div>}
      </div>
      {therapy.bookLabel && (
        <a href={therapy.calendlyUrl || s.calendlyInitial || 'https://calendly.com/sara-lemaitre-herbalist'} target="_blank" rel="noopener" class="therapy-book">{therapy.bookLabel}</a>
      )}
    </div>
    <div class="therapy-content">
      {therapy.paragraphs && therapy.paragraphs.map(p => <p>{p}</p>)}
    </div>
  </section>
))}

{(d.plantStrip1 || d.plantStrip2 || d.plantStrip3 || d.plantStrip4) && (
  <div class="plant-strip">
    {d.plantStrip1 && d.plantStrip1 !== '/images/plant-1.jpg' && <div class="plant-strip-item"><img src={d.plantStrip1} alt="Medicinal plant" /></div>}
    {d.plantStrip2 && d.plantStrip2 !== '/images/plant-2.jpg' && <div class="plant-strip-item"><img src={d.plantStrip2} alt="Medicinal plant" /></div>}
    {d.plantStrip3 && d.plantStrip3 !== '/images/plant-3.jpg' && <div class="plant-strip-item"><img src={d.plantStrip3} alt="Medicinal plant" /></div>}
    {d.plantStrip4 && d.plantStrip4 !== '/images/plant-4.jpg' && <div class="plant-strip-item"><img src={d.plantStrip4} alt="Medicinal plant" /></div>}
  </div>
)}

<section class="th-cta">
  <h2>Not sure which therapy<br>is right for you?<br><em>Start with a conversation.</em></h2>
  <p>Every path through my practice begins with a free 15-minute discovery call. No commitment, no pressure.</p>
  <a href={s.calendlyDiscovery || 'https://calendly.com/sara-lemaitre-herbalist'} target="_blank" rel="noopener">Book a free discovery call</a>
</section>

</BaseLayout>
<script>
  const reveals = document.querySelectorAll('.reveal');
  const obs = new IntersectionObserver(e=>e.forEach(r=>{if(r.isIntersecting){r.target.classList.add('visible');obs.unobserve(r.target)}}),{threshold:0.08});
  reveals.forEach(r=>obs.observe(r));
</script>
