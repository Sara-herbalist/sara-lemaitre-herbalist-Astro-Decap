---
import BaseLayout from '../layouts/BaseLayout.astro';

const meta = {
  title: "Therapies | Herbal Medicine, Naturopathy & Indian Head Massage | Sara Lemaitre",
  description: "Herbal medicine consultations, naturopathy, Indian head massage, TCM-informed plant protocols and athlete performance support. Online and in person, English and French.",
  ogImage: "https://www.saralemaitre.com/images/og-therapies.jpg",
  canonical: "https://www.saralemaitre.com/therapies",
  navLight: false,
  currentPage: 'therapies',
  ogType: 'website',
};
---

<BaseLayout {...meta}>

<style is:global>
:root {
    --cream: #F7F3EE;
    --warm-white: #FDFAF7;
    --sage: #7A8C6E;
    --sage-text: #4E6245;
    --sage-light: #C4D0BA;
    --sage-pale: #EBF0E7;
    --bark: #5C4A3A;
    --bark-light: #8C7060;
    --bark-pale: #EDE5DC;
    --charcoal: #2A2420;
    --muted: #6A5E58;
    --gold: #C4A25A;
    --gold-pale: #F5EDD6;
    --plum: #6B4E6B;
    --plum-pale: #F0EAF0;
    --amber: #B8763A;
    --amber-pale: #FBF0E3;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--warm-white);
    color: var(--charcoal);
    font-family: 'Jost', sans-serif;
    font-size: 1.0625rem;
    font-weight: 300;
    line-height: 1.85;
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 1.5rem 4rem;
    display: flex; justify-content: space-between; align-items: center;
    background: rgba(253,250,247,0.92);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(122,108,100,0.1);
  }
  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem; font-weight: 400;
    letter-spacing: .12em; text-transform: uppercase;
    color: var(--bark); text-decoration: none;
  }
  .nav-links { display: flex; gap: 2.5rem; list-style: none; }
  .nav-links a {
    font-size: .9375rem; letter-spacing: .14em; text-transform: uppercase;
    color: var(--muted); text-decoration: none; transition: color .2s;
  }
  .nav-links a:hover, .nav-links a.active { color: var(--bark); }

  /* ── PAGE HEADER ── */
  .page-header {
    padding: 14rem 8rem 6rem;
    background: var(--cream);
    border-bottom: 1px solid rgba(122,108,100,0.12);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: end;
  }
  .page-header-left {}
  .header-eyebrow {
    font-size: .875rem; letter-spacing: .22em; text-transform: uppercase;
    color: var(--sage-text); margin-bottom: 1.5rem;
    opacity: 0; animation: fadeUp .7s .2s forwards;
  }
  .header-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.8rem, 5vw, 4.2rem);
    font-weight: 300; line-height: 1.1; color: var(--bark);
    opacity: 0; animation: fadeUp .7s .4s forwards;
  }
  .header-title em { font-style: italic; color: var(--sage-text); }
  .page-header-right {
    opacity: 0; animation: fadeUp .7s .5s forwards;
  }
  .header-intro {
    font-size: 1.0625rem; color: var(--muted);
    line-height: 1.95; max-width: 480px;
    border-left: 2px solid var(--sage-light);
    padding-left: 1.5rem;
  }

  /* ── THERAPY NAVIGATION ── */
  .therapy-nav {
    position: sticky; top: 73px; z-index: 50;
    background: rgba(253,250,247,0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(122,108,100,0.1);
    padding: 0 4rem;
    display: flex; gap: 0; overflow-x: auto;
    scrollbar-width: none;
  }
  .therapy-nav::-webkit-scrollbar { display: none; }
  .therapy-nav-item {
    padding: 1.2rem 1.8rem;
    font-size: .9375rem; letter-spacing: .14em; text-transform: uppercase;
    color: var(--muted); text-decoration: none;
    border-bottom: 2px solid transparent;
    white-space: nowrap; transition: all .2s; cursor: pointer;
    background: none; border-top: none; border-left: none; border-right: none;
    font-family: 'Jost', sans-serif;
  }
  .therapy-nav-item:hover { color: var(--bark); }
  .therapy-nav-item.active { color: var(--bark); border-bottom-color: var(--sage-text); }

  /* ── THERAPY SECTIONS ── */
  .therapy-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 85vh;
    border-bottom: 1px solid rgba(122,108,100,0.1);
  }
  .therapy-section.reverse { direction: rtl; }
  .therapy-section.reverse > * { direction: ltr; }

  .therapy-visual {
    position: relative;
    overflow: hidden;
    display: flex; align-items: center; justify-content: center;
  }
  .therapy-section:nth-child(odd) .therapy-visual { background: var(--sage-pale); }
  .therapy-section:nth-child(even) .therapy-visual { background: var(--bark-pale); }
  .therapy-section.plum-bg .therapy-visual { background: var(--plum-pale); }
  .therapy-section.amber-bg .therapy-visual { background: var(--amber-pale); }
  .therapy-section.gold-bg .therapy-visual { background: var(--gold-pale); }

  .therapy-icon-large {
    width: 260px; height: 260px;
    opacity: .15;
  }
  .therapy-number-bg {
    position: absolute; bottom: -1rem; right: -1rem;
    font-family: 'Cormorant Garamond', serif;
    font-size: 16rem; font-weight: 300; line-height: 1;
    color: var(--bark); opacity: .07;
    pointer-events: none;
  }
  .therapy-visual-label {
    position: absolute; bottom: 2.5rem; left: 2.5rem; right: 2.5rem;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem; font-style: italic; color: var(--bark);
    border-left: 2px solid var(--sage); padding-left: 1rem;
    line-height: 1.5;
  }

  .therapy-content {
    padding: 6rem 6rem 6rem 7rem;
    display: flex; flex-direction: column; justify-content: center;
  }
  .therapy-section.reverse .therapy-content {
    padding: 6rem 7rem 6rem 6rem;
  }
  .therapy-tag {
    font-size: .75rem; letter-spacing: .2em; text-transform: uppercase;
    color: var(--sage-text); margin-bottom: 1.2rem;
  }
  .therapy-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3vw, 2.8rem);
    font-weight: 300; color: var(--bark);
    line-height: 1.15; margin-bottom: .8rem;
  }
  .therapy-title em { font-style: italic; color: var(--sage-text); }
  .therapy-subtitle {
    font-size: 1rem; color: var(--muted);
    letter-spacing: .06em; margin-bottom: 2.5rem;
    font-weight: 400;
  }
  .therapy-story {
    font-size: 1.0625rem; color: #4A403C;
    line-height: 1.95; margin-bottom: 1.3rem; max-width: 540px;
  }
  .therapy-story em { font-style: italic; color: var(--sage-text); }
  .therapy-story strong { font-weight: 500; color: var(--bark); }

  /* conditions list */
  .conditions-block {
    margin: 2rem 0;
    padding: 1.5rem 2rem;
    background: var(--cream);
    border-radius: 2px;
    border-left: 3px solid var(--sage);
  }
  .conditions-label {
    font-size: .75rem; letter-spacing: .18em; text-transform: uppercase;
    color: var(--sage-text); margin-bottom: .8rem;
  }
  .conditions-grid {
    display: flex; flex-wrap: wrap; gap: .5rem;
  }
  .condition-tag {
    font-size: .9375rem; padding: .3rem .9rem;
    background: var(--warm-white);
    border: 1px solid rgba(122,140,110,0.3);
    color: var(--bark-light);
    border-radius: 20px;
  }

  /* testimonial */
  .testimonial-block {
    margin: 2rem 0;
    padding: 1.5rem 2rem;
    background: var(--bark);
    border-radius: 2px;
    position: relative;
  }
  .testimonial-block::before {
    content: '"';
    position: absolute; top: .5rem; left: 1.5rem;
    font-family: 'Cormorant Garamond', serif;
    font-size: 4rem; color: var(--sage-light); opacity: .4;
    line-height: 1; pointer-events: none;
  }
  .testimonial-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.125rem; font-style: italic;
    color: var(--cream); line-height: 1.65;
    padding-top: .5rem;
  }
  .testimonial-attribution {
    font-size: .9375rem; letter-spacing: .12em; text-transform: uppercase;
    color: var(--sage-light); margin-top: .8rem; opacity: .7;
  }
  .testimonial-placeholder {
    font-size: .9375rem; letter-spacing: .1em; text-transform: uppercase;
    color: var(--sage-light); opacity: .5; font-style: italic;
  }

  /* session info */
  .session-info {
    display: flex; gap: 2rem; margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(122,108,100,0.15);
    flex-wrap: wrap;
  }
  .session-detail { display: flex; flex-direction: column; gap: .2rem; }
  .session-detail-label {
    font-size: .75rem; letter-spacing: .18em; text-transform: uppercase; color: var(--sage-text);
  }
  .session-detail-value { font-size: 1.0625rem; font-weight: 400; color: var(--bark); }

  .book-link {
    display: inline-block; margin-top: 1.5rem;
    padding: .85rem 2.2rem;
    border: 1px solid var(--bark);
    color: var(--bark); text-decoration: none;
    font-size: .9375rem; letter-spacing: .18em; text-transform: uppercase;
    transition: all .25s; align-self: flex-start;
  }
  .book-link:hover { background: var(--bark); color: var(--warm-white); }

  /* ── HOLISTIC WALKS SECTION ── */
  .walks-section {
    background: var(--sage);
    padding: 8rem;
    color: var(--cream);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
    border-bottom: 1px solid rgba(122,108,100,0.1);
  }
  .walks-text h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3vw, 2.8rem);
    font-weight: 300; line-height: 1.2;
    color: var(--cream); margin-bottom: 2rem;
  }
  .walks-text h2 em { font-style: italic; color: var(--sage-pale); }
  .walks-text p {
    font-size: 1.0625rem; color: rgba(247,243,238,.8);
    line-height: 1.95; margin-bottom: 1.3rem; max-width: 520px;
  }
  .walks-tag {
    font-size: .75rem; letter-spacing: .2em; text-transform: uppercase;
    color: var(--sage-pale); margin-bottom: 1.2rem;
  }
  .walks-seasons {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
  }
  .season-card {
    padding: 1.5rem;
    border: 1px solid rgba(247,243,238,.2);
    border-radius: 2px;
  }
  .season-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem; color: var(--cream); margin-bottom: .4rem;
  }
  .season-desc {
    font-size: 1rem; color: rgba(247,243,238,.6); line-height: 1.6;
  }

  /* ── WORKSHOPS SECTION ── */
  .workshops-section {
    padding: 8rem;
    background: var(--cream);
    border-bottom: 1px solid rgba(122,108,100,0.12);
  }
  .workshops-inner { max-width: 1000px; margin: 0 auto; }
  .workshops-header { margin-bottom: 4rem; }
  .workshops-header .eyebrow {
    font-size: .875rem; letter-spacing: .22em; text-transform: uppercase;
    color: var(--sage-text); margin-bottom: 1.2rem;
  }
  .workshops-header h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3vw, 2.8rem);
    font-weight: 300; color: var(--bark); line-height: 1.2;
    max-width: 600px;
  }
  .workshops-header h2 em { font-style: italic; color: var(--sage-text); }
  .workshops-grid {
    display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 1.5rem;
  }
  .workshop-card {
    padding: 2rem;
    background: var(--warm-white);
    border: 1px solid rgba(122,108,100,0.12);
    transition: border-color .2s;
  }
  .workshop-card:hover { border-color: var(--sage-text); }
  .workshop-icon {
    font-size: 1.4rem; margin-bottom: 1rem;
  }
  .workshop-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem; font-weight: 400; color: var(--bark);
    margin-bottom: .6rem; line-height: 1.2;
  }
  .workshop-desc {
    font-size: 1rem; color: var(--muted); line-height: 1.75;
  }

  /* ── PRODUCTS SECTION ── */
  .products-section {
    display: grid; grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid rgba(122,108,100,0.12);
  }
  .products-text {
    padding: 8rem;
    background: var(--warm-white);
    display: flex; flex-direction: column; justify-content: center;
  }
  .products-text .eyebrow {
    font-size: .875rem; letter-spacing: .22em; text-transform: uppercase;
    color: var(--sage-text); margin-bottom: 1.5rem;
  }
  .products-text h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3vw, 2.8rem);
    font-weight: 300; color: var(--bark);
    line-height: 1.2; margin-bottom: 2rem;
  }
  .products-text h2 em { font-style: italic; color: var(--sage-text); }
  .products-text p {
    font-size: 1.0625rem; color: #4A403C;
    line-height: 1.95; margin-bottom: 1.3rem; max-width: 480px;
  }
  .product-types {
    margin-top: 1rem; display: flex; flex-direction: column; gap: .8rem;
  }
  .product-type-item {
    display: flex; gap: 1rem; align-items: flex-start;
    padding: 1rem 1.2rem;
    border: 1px solid rgba(122,108,100,0.12);
    background: var(--cream);
  }
  .product-type-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--sage); flex-shrink: 0; margin-top: .55rem;
  }
  .product-type-name { font-size: 1.0625rem; font-weight: 400; color: var(--bark); }
  .product-type-desc { font-size: 1rem; color: var(--muted); line-height: 1.5; margin-top: .2rem; }
  .products-visual {
    background: var(--bark-pale);
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
    padding: 4rem;
  }
  .products-visual-text {
    position: absolute; bottom: 3rem; left: 3rem; right: 3rem;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem; font-style: italic; color: var(--bark);
    border-left: 2px solid var(--sage); padding-left: 1rem; line-height: 1.5;
  }

  /* ── CTA SECTION ── */
  .cta-section {
    background: var(--bark);
    padding: 8rem;
    text-align: center;
  }
  .cta-section h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 300; color: var(--cream);
    line-height: 1.3; margin-bottom: 1.5rem; max-width: 640px; margin-left: auto; margin-right: auto;
  }
  .cta-section h2 em { font-style: italic; color: var(--sage-light); }
  .cta-section p {
    font-size: 1.0625rem; color: rgba(247,243,238,.7);
    line-height: 1.9; max-width: 540px;
    margin: 0 auto 3rem;
  }
  .cta-buttons { display: flex; gap: 1.2rem; justify-content: center; flex-wrap: wrap; }
  .cta-primary {
    display: inline-block; padding: 1rem 3rem;
    background: var(--sage-light); color: var(--bark);
    text-decoration: none; font-size: .9375rem;
    letter-spacing: .18em; text-transform: uppercase;
    transition: all .25s;
  }
  .cta-primary:hover { background: var(--cream); }
  .cta-secondary {
    display: inline-block; padding: 1rem 3rem;
    border: 1px solid rgba(247,243,238,.3); color: rgba(247,243,238,.7);
    text-decoration: none; font-size: .9375rem;
    letter-spacing: .18em; text-transform: uppercase;
    transition: all .25s;
  }
  .cta-secondary:hover { border-color: var(--sage-light); color: var(--sage-light); }

  /* ── FOOTER ── */
  .footer-strip {
    background: var(--charcoal);
    padding: 2.5rem 8rem;
    display: flex; justify-content: space-between; align-items: center;
  }
  .footer-strip p {
    font-size: .9375rem; letter-spacing: .1em;
    color: rgba(247,243,238,0.3);
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity .7s ease, transform .7s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  @media (max-width: 1000px) {
    nav { padding: 1.2rem 2rem; }
    .page-header { grid-template-columns: 1fr; padding: 10rem 2.5rem 4rem; gap: 2rem; }
    .therapy-nav { padding: 0 2rem; }
    .therapy-section, .therapy-section.reverse { grid-template-columns: 1fr; direction: ltr; }
    .therapy-visual { min-height: 260px; }
    .therapy-content { padding: 4rem 2.5rem; }
    .therapy-section.reverse .therapy-content { padding: 4rem 2.5rem; }
    .walks-section { grid-template-columns: 1fr; padding: 5rem 2.5rem; gap: 3rem; }
    .workshops-section { padding: 5rem 2.5rem; }
    .workshops-grid { grid-template-columns: 1fr; }
    .products-section { grid-template-columns: 1fr; }
    .products-text { padding: 5rem 2.5rem; }
    .products-visual { min-height: 300px; }
    .cta-section { padding: 5rem 2.5rem; }
    .footer-strip { padding: 2rem 2.5rem; flex-direction: column; gap: 1rem; text-align: center; }
  }

  /* ── WCAG 2.2 AA: Visible focus indicators ── */
  :focus-visible {
    outline: 3px solid #5C4A3A;
    outline-offset: 3px;
    border-radius: 2px;
  }
  a:focus-visible, button:focus-visible, input:focus-visible,
  select:focus-visible, textarea:focus-visible {
    outline: 3px solid #5C4A3A;
    outline-offset: 3px;
  }

  /* Screen-reader only utility */
  .sr-only {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }

  /* ── Skip navigation link ── */
  .skip-nav {
    position: absolute; top: -100px; left: 1rem; z-index: 9999;
    background: #5C4A3A; color: #F7F3EE;
    padding: .75rem 1.5rem; font-size: 1.0625rem;
    text-decoration: none; border-radius: 0 0 4px 4px;
    transition: top .2s;
  }
  .skip-nav:focus { top: 0; }


  /* ── Mobile hamburger menu ── */
  .hamburger {
    display: none; flex-direction: column; gap: 5px;
    background: none; border: none; cursor: pointer;
    padding: .5rem; margin-left: .5rem;
  }
  .hamburger span {
    display: block; width: 22px; height: 2px;
    background: var(--bark); border-radius: 2px;
    transition: all .25s;
  }
  .hamburger[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .hamburger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  
  @media (max-width: 1024px) {
    .hamburger { display: flex; }
    .nav-links {
      display: none; position: fixed; top: 73px; left: 0; right: 0;
      background: rgba(253,250,247,0.98); backdrop-filter: blur(12px);
      flex-direction: column; gap: 0; padding: 1rem 0;
      border-bottom: 1px solid rgba(122,108,100,0.12);
      z-index: 99;
    }
    .nav-links.open { display: flex; }
    .nav-links li a {
      display: block; padding: .9rem 2rem;
      font-size: 1.0625rem; letter-spacing: .08em;
      border-bottom: 1px solid rgba(122,108,100,0.06);
    }
    .nav-book { display: none; }
  }



  .lang-toggle {
    font-size: .75rem; letter-spacing: .16em; text-transform: uppercase;
    padding: .45rem .9rem; border: 1px solid rgba(247,243,238,.5);
    background: none; color: rgba(247,243,238,.85); cursor: pointer;
    font-family: 'Jost', sans-serif; border-radius: 2px;
    transition: all .3s; margin-left: .5rem;
  }
  nav.scrolled .lang-toggle { border-color: rgba(92,74,58,.35); color: var(--muted); }
  .lang-toggle:hover, nav.scrolled .lang-toggle:hover { border-color: var(--bark); color: var(--bark); }


  /* Pages with light-coloured heroes — nav starts dark */
  body[data-nav="light"] nav {
    background: rgba(253,250,247,0.85);
    backdrop-filter: blur(8px);
  }
  body[data-nav="light"] .nav-logo { color: var(--bark); }
  body[data-nav="light"] .nav-links a { color: var(--muted); }
  body[data-nav="light"] .nav-links a:hover { color: var(--bark); }
  body[data-nav="light"] .nav-book { border-color: var(--bark); color: var(--bark); }
  body[data-nav="light"] .lang-toggle { border-color: rgba(92,74,58,.35); color: var(--muted); }
</style>

<!-- PAGE HEADER -->
<header id="main-content" role="main" class="page-header">
  <div class="page-header-left">
    <p class="header-eyebrow">What I offer</p>
    <h1 class="header-title">Therapies that<br>work <em>with</em> you,<br>not on you</h1>
  </div>
  <div class="page-header-right">
